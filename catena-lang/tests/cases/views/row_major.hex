# Build a row-major 2D matrix view from runtime memory, then materialize the
# diagonal into a new flat buffer. For a 3 x 3 input laid out as:
#
#   [10, 11, 12,
#    20, 21, 22,
#    30, 31, 32]
#
# the returned buffer should be `[10, 21, 32]`.

(theory program type {
  # Runtime check/proof that a flat length k is the square matrix length n * n.
  (arr u64.assert-square-length :
    {[n k.]
      ({[.k] u64} :)
      ({[.n] u64} :)
    }
    ->
    ([n k.] ([.n n] * [nn.]) ([.nn k] = |-))
  )

  # Convert a diagonal materialization index into a 2D index.
  (def matrix-diagonal-index :
    ([n.] ([.n] ix val))
    ->
    {[n.] ({([.n] ix val) ([.n] ix val)} *)}
  = ([i.] {[.i i]} *.intro))
})

# Runtime memory -> square u64 buffer -> row-major view -> diagonal memory.
(def program matrix-diagonal-u64 :
  {[n.]
    ({[.n] u64} :)
    (cap.ref mem)
  }
  ->
  {[n.] (cap.own mem)}
= ([dim input.]
  {
    ([.dim] :.copy [dim-name-source dim-rest.])
    ([.dim-name-source] :.name [dim-name.])
    ([.dim-rest] :.copy [dim-proof dim-rest2.])
    ([.dim-rest2] :.copy [dim-view dim-rest3.])
    ([.dim-rest3] :.copy [dim-materialize dim-out.])

    ([.input] mem.cast.u64 [flat-len flat-buffer.])
    ({[.flat-len dim-proof]} u64.assert-square-length [square-length.])
    ({[.flat-buffer square-length]} buf.u64.cast-same-length [buffer.])

    # matrix : val(ix n) * val(ix n) => val(u64)
    ({[.dim-view buffer]} buf.row-major-view [matrix.])

    # diagonal-index : val(ix n) => val(ix n) * val(ix n)
    ([.dim-name] name.matrix-diagonal-index lift [diagonal-index.])
    ({[.diagonal-index matrix]} compose [diagonal-view.])
    ([.diagonal-view] val.wrap [diagonal-view-val.])

    ({[.dim-materialize diagonal-view-val]} materialize [out-buffer.])
  }
  ({[.dim-out out-buffer]} buf.to-mem)
))
