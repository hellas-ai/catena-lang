# Build a row-major 2D matrix view from runtime memory, then sum its diagonal
# through source-level reduce. This avoids materialize while still exercising
# closure conversion from reduce to reducec.
#
# For a 3 x 3 input laid out as:
#
#   [10, 11, 12,
#    20, 21, 22,
#    30, 31, 32]
#
# the result should be `10 + 21 + 32 = 63`.

(theory program type {
  # Runtime check/proof that a flat length k is the square matrix length n * n.
  (arr u64.assert-square-length :
    {[n k.]
      ({[.k] u64} :)
      ({[.n] u64} :)
    }
    ->
    ([n k.] ([.n n] * [nn.]) ([.nn k] = |-))
  )

  # Adapter from the reduce accumulator closure convention to direct u64.add.
  (def u64.add-reduce :
    ({(u64 val) (u64 val)} *)
    ->
    (u64 val)
  = ([pair.]
    ([.pair] *.elim [acc value.])
    {[.acc value]} u64.add
  ))

  # Convert a diagonal reduction index into the 2D row/column index expected by
  # buf.row-major-view.
  (def matrix-diagonal-index :
    ([n.] ([.n] ix val))
    ->
    {[n.] ({([.n] ix val) ([.n] ix val)} *)}
  = ([i. i i] *.intro))
})

# Runtime memory -> square u64 buffer -> row-major view -> diagonal sum.
(def program matrix-diagonal-sum-u64 :
  {[n.]
    ({[.n] u64} :)
    (cap.ref mem)
  }
  ->
  {[n.] (u64 val)}
= ([dim input.]
  {
    ([.dim] :.copy [dim-name-source dim-rest.])
    ([.dim-name-source] :.name [dim-name.])
    ([.dim-rest] :.copy [dim-proof dim-rest2.])
    ([.dim-rest2] :.copy [dim-view dim-reduce.])

    ([.input] mem.cast.u64 [flat-len flat-buffer.])
    ({[.flat-len dim-proof]} u64.assert-square-length [square-length.])
    ({[.flat-buffer square-length]} buf.u64.cast-same-length [buffer.])

    # matrix : val(ix n) * val(ix n) => val(u64)
    ({[.dim-view buffer]} buf.row-major-view [matrix.])

    # diagonal-view : val(ix n) => val(u64)
    ([.dim-name] name.matrix-diagonal-index lift [diagonal-index.])
    ({[.diagonal-index matrix]} compose [diagonal-view.])

    const.u64.0x0000000000000000
    (name.u64.add-reduce lift)
    [.diagonal-view]
    [.dim-reduce]
  }
  reduce
))
