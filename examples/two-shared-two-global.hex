#
# Exercise two 2D shared-memory buffers and two 2D global-memory buffers.
#

(def data user.f32.two-shared-two-global : 
    {
      (([.block_count] extent) val)
      (([.thread_count] extent) val)
      (([.tile_rows] extent) val)
      (([.tile_cols] extent) val)
      (({([block_count] 1d) ([thread_count] 1d)} gpu.grid) val)
      (({f32 ({[tile_rows] [tile_cols]} 2d)} gpu.shared) val)
      (({f32 ({[tile_rows] [tile_cols]} 2d)} gpu.shared) val)
      (({f32 ({[block_count] [thread_count]} 2d)} gpu.global) val)
      (({f32 ({[block_count] [thread_count]} 2d)} gpu.global) val)
    } ->
    {
      [block_count thread_count.]
      (({f32 ({[tile_rows] [tile_cols]} 2d)} gpu.shared) val)
      (({f32 ({[tile_rows] [tile_cols]} 2d)} gpu.shared) val)
      (({f32 ({[block_count] [thread_count]} 2d)} gpu.global) val)
      (({f32 ({[block_count] [thread_count]} 2d)} gpu.global) val)
    }
    = {[block_count thread_count tile_rows tile_cols grid tile_a tile_b out_a out_b.]
      ([.grid] gpu.grid.schedule [block thread.])
      ([.block thread thread_count] gpu.view.group [out_view.])
      ([.thread] gpu.view.element [tile_view.])
      ([.] f32.one [one.])
      ([.] f32.zero [zero.])
      ([.tile_a tile_view one] gpu.shared.store [tile_a_filled.])
      ([.tile_b tile_view zero] gpu.shared.store [tile_b_filled.])
      ([.tile_a_filled tile_view] gpu.shared.load [from_tile_a.])
      ([.tile_b_filled tile_view] gpu.shared.load [from_tile_b.])
      ([.out_a out_view from_tile_a] gpu.global.store [out_a_filled.])
      ([.out_b out_view from_tile_b] gpu.global.store [out_b_filled.])
      [.tile_a_filled tile_b_filled out_a_filled out_b_filled]}
)
