# 4-term Taylor approximation around 0:
# x - x^3/3! + x^5/5! - x^7/7!
(def program sin-approx : (f32 val) -> (f32 val) =
  {[x.]
    ([.x x] f32.mul [x2.])
    ([.x2 x] f32.mul [x3.])
    ([.x3 x2] f32.mul [x5.])
    ([.x5 x2] f32.mul [x7.])

    ([.] const.u32.0x00000006 [fact_3_u32.])
    ([.] const.u32.0x00000078 [fact_5_u32.])
    ([.] const.u32.0x000013B0 [fact_7_u32.])

    ([.fact_3_u32] u32.to-f32 [fact_3.])
    ([.fact_5_u32] u32.to-f32 [fact_5.])
    ([.fact_7_u32] u32.to-f32 [fact_7.])

    ([.x3 fact_3] f32.div [x3_over_6.])
    ([.x5 fact_5] f32.div [x5_over_120.])
    ([.x7 fact_7] f32.div [x7_over_5040.])

    ([.x x3_over_6] f32.sub [partial1.])
    ([.partial1 x5_over_120] f32.add [partial2.])
    ([.partial2 x7_over_5040] f32.sub [result.])
    [.result]
  }
)

# 4-term cosine approximation around 0:
# 1 - x^2/2! + x^4/4! - x^6/6!
(def program cos-approx : (f32 val) -> (f32 val) =
  {[x.]
    ([.x x] f32.mul [x2.])
    ([.x2 x2] f32.mul [x4.])
    ([.x4 x2] f32.mul [x6.])

    ([.] const.u32.0x00000002 [fact_2_u32.])
    ([.] const.u32.0x00000018 [fact_4_u32.])
    ([.] const.u32.0x000002D0 [fact_6_u32.])

    ([.fact_2_u32] u32.to-f32 [fact_2.])
    ([.fact_4_u32] u32.to-f32 [fact_4.])
    ([.fact_6_u32] u32.to-f32 [fact_6.])
    ([.] const.u32.0x00000001 [one_u32.])
    ([.one_u32] u32.to-f32 [one.])

    ([.x2 fact_2] f32.div [x2_over_2.])
    ([.x4 fact_4] f32.div [x4_over_24.])
    ([.x6 fact_6] f32.div [x6_over_720.])

    ([.one x2_over_2] f32.sub [partial1.])
    ([.partial1 x4_over_24] f32.add [partial2.])
    ([.partial2 x6_over_720] f32.sub [result.])
    [.result]
  }
)

# Cody-Waite style range reduction for non-negative inputs:
# n = round(x * 2/pi), r = x - n * pio2_hi - n * pio2_lo
# then choose sin/cos and sign from quadrant n mod 4.
(def program sin-approx-full : (f32 val) -> (f32 val) =
  {[x.]
    ([.] const.u32.0x3F22F983 [inv_pio2_bits.])
    ([.] const.u32.0x3FC90FDA [pio2_hi_bits.])
    ([.] const.u32.0x33A22168 [pio2_lo_bits.])

    ([.inv_pio2_bits] u32.bitcast-f32 [inv_pio2.])
    ([.pio2_hi_bits] u32.bitcast-f32 [pio2_hi.])
    ([.pio2_lo_bits] u32.bitcast-f32 [pio2_lo.])

    ([.x inv_pio2] f32.mul [scaled.])
    ([.scaled] f32.round-to-u32 [n_u32.])
    ([.n_u32] u32.to-f32 [n_f.])

    ([.n_f pio2_hi] f32.mul [n_pio2_hi.])
    ([.n_f pio2_lo] f32.mul [n_pio2_lo.])
    ([.x n_pio2_hi] f32.sub [r1.])
    ([.r1 n_pio2_lo] f32.sub [r.])

    ([.r] sin-approx [sin_r.])
    ([.r] cos-approx [cos_r.])
    ([.sin_r] f32.neg [neg_sin_r.])
    ([.cos_r] f32.neg [neg_cos_r.])

    ([.] const.u32.0x00000003 [mask3.])
    ([.] const.u32.0x00000000 [q0_u32.])
    ([.] const.u32.0x00000001 [q1_u32.])
    ([.] const.u32.0x00000002 [q2_u32.])

    ([.n_u32 mask3] u32.and [quadrant.])
    ([.quadrant q0_u32] u32.eq [is_q0.])
    ([.quadrant q1_u32] u32.eq [is_q1.])
    ([.quadrant q2_u32] u32.eq [is_q2.])

    ([.is_q2 neg_sin_r neg_cos_r] f32.select [q23.])
    ([.is_q1 cos_r q23] f32.select [q123.])
    ([.is_q0 sin_r q123] f32.select [result.])
    [.result]
  }
)
