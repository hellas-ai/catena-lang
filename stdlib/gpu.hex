(theory syntax nat {

  (arr gpu.block : 0 -> 1)
  (arr gpu.thread : 0 -> 1)
  (arr gpu.global : 2 -> 1)
  (arr gpu.view : 0 -> 1)
  (arr gpu.index : 0 -> 1)
  (arr gpu.shared : 2 -> 1)
  (arr 1d : 1 -> 1)
  (arr 2d : 2 -> 1)
  (arr 3d : 3 -> 1)
  (arr gpu.grid : 2 -> 1)

})

(theory data syntax {

  (arr gpu.grid.schedule :
    (({[block_dim] [thread_dim]} gpu.grid) val) ->
    ([block_dim thread_dim .] {(gpu.block val) (gpu.thread val)}))

  (arr gpu.view.group :
    {(gpu.block val) (gpu.thread val) (([block_size] extent) val)} ->
    ([block_size .] (gpu.view val)))

  (arr gpu.view.group-by-tile :
    {(gpu.block val) (gpu.thread val) (([tile_rows] extent) val) (([tile_cols] extent) val)} ->
    ([tile_rows tile_cols .] (gpu.view val)))

  # TODO: consolidate group-by-tile and group-by-shape into one generic
  # grouping/index-composition primitive once view ranks/shapes are explicit.

  (arr gpu.view.row :
    (gpu.view val) ->
    (gpu.view val))

  (arr gpu.view.col :
    (gpu.view val) ->
    (gpu.view val))

  (arr gpu.view.zero :
    [] ->
    (gpu.view val))

  (arr gpu.view.group-by-shape :
    {(gpu.view val) (gpu.view val) (([rows] extent) val) (([cols] extent) val)} ->
    ([rows cols .] (gpu.view val)))

  (arr gpu.view.element :
    (gpu.thread val) ->
    (gpu.view val))

  (arr gpu.view.sub :
    {(gpu.view val) (([offset] index) val)} ->
    ([offset.] (gpu.index val)))

  (arr gpu.view.ge :
    {(gpu.view val) (([offset] index) val)} ->
    ([offset.] (2 val)))

  (arr gpu.index.nonnegative :
    (gpu.index val) ->
    (2 val))

  (arr gpu.index.lt-extent :
    {(gpu.index val) (([size] extent) val)} ->
    ([size.] (2 val)))

  (arr gpu.global.store :
    {([matrix] val) (gpu.view val) (f32 val)} ->
    ([matrix . matrix] val))

  (arr gpu.global.load :
    {([matrix] val) (gpu.view val)} ->
    ([matrix.] (f32 val)))

  # Conditional global load with caller-chosen fallback.
  # Example:
  #   ([.in_bounds input i zero] gpu.global.load-if [value.])
  # means:
  #   value = in_bounds ? input[i] : zero
  # Use only when the fallback is meaningful for the algorithm.
  (arr gpu.global.load-if :
    {(2 val) ([matrix] val) (gpu.index val) (f32 val)} ->
    ([matrix.] (f32 val)))

  # Bounds-checked global load with caller-chosen fallback.
  # Example:
  #   ([.input i input_size zero] gpu.global.load-or [value.])
  # means:
  #   value = (0 <= i < input_size) ? input[i] : zero
  # This is memory-safe, but the fallback still defines the math.
  (arr gpu.global.load-or :
    {([matrix] val) (gpu.index val) (([size] extent) val) (f32 val)} ->
    ([matrix size.] (f32 val)))

  (arr gpu.shared.load :
    {([tile] val) (gpu.view val)} ->
    ([tile.] (f32 val)))

  # Conditional shared-memory load with caller-chosen fallback.
  # Example:
  #   ([.use_tile scratch local_i fallback] gpu.shared.load-if [value.])
  # means:
  #   value = use_tile ? scratch[local_i] : fallback
  (arr gpu.shared.load-if :
    {(2 val) ([tile] val) (gpu.index val) (f32 val)} ->
    ([tile.] (f32 val)))

  # Bounds-checked shared-memory load with caller-chosen fallback.
  # Example:
  #   ([.scratch local_i tile_size fallback] gpu.shared.load-or [value.])
  # means:
  #   value = (0 <= local_i < tile_size) ? scratch[local_i] : fallback
  (arr gpu.shared.load-or :
    {([tile] val) (gpu.index val) (([size] extent) val) (f32 val)} ->
    ([tile size.] (f32 val)))

  (arr gpu.shared.store :
    {([tile] val) (gpu.view val) (f32 val)} ->
    ([tile . tile] val))

  (arr gpu.sync :
    ([x] val) ->
    ([x] val))

})
