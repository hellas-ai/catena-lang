# Catena-lang analogue of examples/puzzles/pooling.hex.
#
# This file declares the extra index/product/buffer primitives it needs locally,
# instead of extending catena-lang/stdlib/*.hex.
#
# It models the per-index pooling behavior:
#
#   output[0] = input[0]
#   output[1] = input[1] + input[0]
#   output[i] = input[i] + input[i - 1] + input[i - 2], for i >= 2
#
# Unlike the core example, this does not use gpu.global or gpu views. It uses a
# simple input/output buffers plus an index. The nested branch program computes
# the pooled value at that index; the store wrapper writes it to the output.
#
# NOTE: this is a language-level example. The current catena-lang HIP renderer
# does not yet lower these locally declared f32/index primitives.

(theory type nat {
  (arr != : 2 -> 1)
})

(theory program type {
  # Local numeric/index primitives for this example.
  # Branch-producing predicates: the boolean controls `bool.ifc`, while the
  # propositions are threaded as branch environments.
  (arr u64.eq : {[x y.]
    ({[.x] u64} :)
    ({[.y] u64} :)
  } -> {[x y.]
    (bool val)
    ([.x y] = |-) # selected branch: x = y
    ([.x y] != |-) # non-selected branch: x != y
  })
  (arr u64.one.type : [] -> ({1 u64} :))
  (arr u64.one.gt-zero : {[x.]
    ([.x 1] = |-) 
  } -> {[x.]
    ([.x 0] > |-) 
  })
  (arr u64.neq-zero-neq-one.gt-one : {[x.]
    ([.x 0] != |-) 
    ([.x 1] != |-) 
  } -> {[x.]
    ([.x 1] > |-) 
  })
  (arr u64.pred : {[x y pred.]
    ({[.x] u64} :)
    ([.x y] > |-)
  } -> {[x y pred.]
    ({[.pred] u64} :)
  })
  (arr u64.pred.gt-zero : {[x pred.]
    ([.x 1] > |-)
    ({[.pred] u64} :)
  } -> {[x pred.]
    ([.pred 0] > |-)
  })

  # Extract the numeric value of a valid index together with its range proof.
  (arr ix.index : {[n x.]
    ([.n] ix val)
  } -> {[n x.]
    ({[.x] u64} :)
    ([.n x] > |-) 
  })
  (arr u64.pred.lt-n : {[n x y pred.]
    ([.n x] > |-) 
    ([.x y] > |-)
    ({[.pred] u64} :)
  } -> {[n x y pred.]
    ([.n pred] > |-) 
  })
  (arr ix.from-u64 : {[n x.]
    ({[.x] u64} :)
    ([.n x] > |-) 
  } -> {[n x.]
    ([.n] ix val)
  })
  (def pool.payload.intro :
    {[n x.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
      ({[.x] u64} :)
      ([.n x] > |-) 
    }
    ->
    {[n x.]
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.x] u64} :)
            ([.n x] > |-) 
          } *)
        } *)
      } *)
    }
    =
    ([input index position position_lt_n.]
      [.position position_lt_n] * [position_range.]
      [.index position_range] * [index_position_range.]
      [.input index_position_range] * [payload.]
      [.payload]
    ))
  (def pool.payload.elim :
    {[n x.]
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.x] u64} :)
            ([.n x] > |-) 
          } *)
        } *)
      } *)
    }
    ->
    {[n x.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
      ({[.x] u64} :)
      ([.n x] > |-) 
    }
    =
    ([payload.]
      [.payload] * [input index_position_range.]
      [.index_position_range] * [index position_range.]
      [.position_range] * [position position_lt_n.]
      [.input index position position_lt_n]
    ))
  (arr f32.buf.store :
    {[n.]
      ({cap.own [.n] f32} buf val)
      ([.n] ix val)
      (f32 val)
    }
    ->
    {[n.]
      ({cap.own [.n] f32} buf val)
    })

  (def f32.pool-at-zero :
    {[n x.]
      ([.x 0] = |-)
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.x] u64} :)
            ([.n x] > |-) 
          } *)
        } *)
      } *)
    }
    -> {[n x.] (f32 val)}
    =
    ([env payload.]
      [.payload] pool.payload.elim [input index position position_lt_n.]
      [.index input] ix [current.]
      [.current]
    ))

  (def f32.pool-at-one :
    {[n x.]
      ([.x 0] > |-)
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.x] u64} :)
            ([.n x] > |-) 
          } *)
        } *)
      } *)
    }
    -> {[n x.] (f32 val)}
    =
    ([env payload.]
      [.payload] pool.payload.elim [input index position position_lt_n.]
      [.position env] u64.pred [prev_position.]
      [.position_lt_n env prev_position] u64.pred.lt-n [prev_lt_n.]
      [.prev_position prev_lt_n] ix.from-u64 [index_prev.]
      [.index input] ix [current.]
      [.index_prev input] ix [previous.]
      [.current previous] f32.add [sum.]
      [.sum]
    ))

  (def f32.pool-at-many :
    {[n x.]
      ([.x 1] > |-)
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.x] u64} :)
            ([.n x] > |-) 
          } *)
        } *)
      } *)
    }
    -> {[n x.] (f32 val)}
    =
    ([env payload.]
      [.payload] pool.payload.elim [input index position position_lt_n.]
      [.position env] u64.pred [prev_position.]
      [.env prev_position] u64.pred.gt-zero [prev_gt_zero.]
      [.position_lt_n env prev_position] u64.pred.lt-n [prev_lt_n.]
      [.prev_position prev_lt_n] ix.from-u64 [index_prev.]
      [.prev_position prev_gt_zero] u64.pred [prev2_position.]
      [.prev_lt_n prev_gt_zero prev2_position] u64.pred.lt-n [prev2_lt_n.]
      [.prev2_position prev2_lt_n] ix.from-u64 [index_prev2.]
      [.index input] ix [current.]
      [.index_prev input] ix [previous.]
      [.index_prev2 input] ix [previous2.]
      [.current previous] f32.add [partial.]
      [.partial previous2] f32.add [sum.]
      [.sum]
    ))

})

(def program f32.pool-nonzero :
  {[n x.]
    ([.x 0] != |-)
    ({
      ({cap.ref [.n] f32} buf val)
      ({
        ([.n] ix val)
        ({
          ({[.x] u64} :)
          ([.n x] > |-) 
        } *)
      } *)
    } *)
  }
  ->
  {[n x.] (f32 val)}
  =
  ([env payload.]
    [.payload] pool.payload.elim [input index position position_lt_n.]
    [] u64.one.type [one.]
    [.position one] u64.eq [is_one one_case many_case.]
    [.one_case] u64.one.gt-zero [one_gt_zero.]
    [.env many_case] u64.neq-zero-neq-one.gt-one [many_gt_one.]
    {
      ([.input index position position_lt_n] pool.payload.intro [payload_checked.])
      ([.is_one])
      ([.one_gt_zero])
      ([.many_gt_one])
    }

    {
      [.one_gt_zero]
      name.f32.pool-at-one
      [.many_gt_one]
      name.f32.pool-at-many
      [. is_one payload_checked]
    }
    bool.ifc
  )
)

(def program f32.pooling-last-three :
  {[n.]
    ({cap.ref [.n] f32} buf val)
    ({cap.own [.n] f32} buf val)
    ([.n] ix val)
  }
  ->
  {[n.]
    ({cap.own [.n] f32} buf val)
  }
  =
  ([input output index.]
    [.index] ix.index [position position_lt_n.]
    [] u64.zero [zero.]
    [.position zero] u64.eq [is_zero zero_case nonzero_case.]

    {
      ([.input index position position_lt_n] pool.payload.intro [payload.])
      ([.is_zero])
      ([.zero_case])
      ([.nonzero_case])
    }

    # Outer if:
    #   if index == 0:
    #     input[index]
    #   else:
    #     run the nested non-zero decision above
    {
      [.zero_case]
      name.f32.pool-at-zero
      [.nonzero_case]
      name.f32.pool-nonzero
      [. is_zero payload]
    }
    bool.ifc [pooled.]

    [.output index pooled] f32.buf.store [output_pooled.]

    [.output_pooled]
  )
)
