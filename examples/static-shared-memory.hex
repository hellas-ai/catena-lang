#
# Static shared-memory target example.
#
#

(def data user.f32.static-shared-one : 
    {
      (([.global_rows] extent) val)
      (([.global_cols] extent) val)
      (([.tile_rows] extent) val)
      (([.tile_cols] extent) val)
      (({
          ({
            (({[global_rows] [tile_rows]} nat.ceil-div) [grid_rows])
            (({[global_cols] [tile_cols]} nat.ceil-div) [grid_cols])
          } 2d) # Blocks in a grid
          ({[tile_rows] [tile_cols]} 2d) # Threads in a block
        } gpu.grid) val)
      (({f32 ({[tile_rows] [tile_cols]} 2d)} gpu.shared) val)
      (({f32 ({[global_rows] [global_cols]} 2d)} gpu.global) val)
    } ->
    {
      [global_rows global_cols tile_rows tile_cols grid_rows grid_cols.]
      (({f32 ({[tile_rows] [tile_cols]} 2d)} gpu.shared) val)
      (({f32 ({[global_rows] [global_cols]} 2d)} gpu.global) val)
    }
    = {[global_rows global_cols tile_rows tile_cols grid tile out.]
      ([.grid] gpu.grid.schedule [block thread.])
      ([.block thread tile_cols] gpu.view.group [out_view.])
      ([.thread] gpu.view.element [tile_view.])
      ([.] f32.one [one.])
      ([.tile tile_view one] gpu.shared.store [tile_filled.])
      ([.tile_filled tile_view] gpu.shared.load [from_tile.])
      ([.out out_view from_tile] gpu.global.store [out_filled.])
      [.tile_filled out_filled]}
)
