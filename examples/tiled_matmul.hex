(theory syntax nat {
  (arr nat : 0 -> 1)
  (arr extent : 1 -> 1)
  (arr index : 1 -> 1)
  (arr bool : 0 -> 1)
  (arr f32 : 0 -> 1)
  (arr block : 0 -> 1)
  (arr thread : 0 -> 1)
  # gpu.global(f32, rows, cols) => global float matrix [rows][cols]
  (arr gpu.global : 3 -> 1)
  # gpu.shared(f32, tile_num, tile_num) => float [tile_num][tile_num]
  # we could use literals instead of nats
  (arr gpu.shared : 3 -> 1)

  (arr value : 1 -> 1)
  (arr bound : 1 -> 1)

  (arr product : 2 -> 1)
  (arr coproduct : 2 -> 1)
  (arr unit : 0 -> 1)
  (arr counit : 0 -> 1)
})

(theory data syntax {
  (arr block : [] -> block)
  (arr thread : [] -> thread)

  (arr global : [n] -> ([n . n n] {f32 [n] [n]} gpu.global))
  (arr shared : [n] -> ([n . n n] {f32 [n] [n]} gpu.shared))
  (arr f32 : [] -> f32)

  (arr value.type : value -> [t])
  (arr extent.raw : extent -> [n])
  (arr extent.index-type : extent -> index)
  (arr bound.eta : [t] -> ([t . t t] {bound value}))

  (arr reduce-f32 :
    {
      (extent value)
      (f32 value)
      (f32 bound)
      (([tile_num] index) bound)
      (f32 value)
    } ->
    ([tile_num tile_num.] f32 value))

  (arr thread.x :
    {([tile_num] extent value) (thread value)} ->
    (([tile_num] index) value))

  (arr thread.y :
    {([tile_num] extent value) (thread value)} ->
    (([tile_num] index) value))

  (arr gpu.shared.load :
    {[tile ix iy]} ->
    ([tile ix iy.] f32 value))

  (arr block.row :
    {([tile_num] extent value) (block value) (thread value)} ->
    (([tile_num] index) value))

  (arr block.col :
    {([tile_num] extent value) (block value) (thread value)} ->
    (([tile_num] index) value))

  (arr p.tile-offset :
    {[tile_extent p local]} ->
    ([tile_extent p local . tile_extent] index value))

  (arr gpu.global.load :
    {[matrix row col]} ->
    ([matrix row col.] f32 value))

  (arr gpu.shared.store :
    {[tile row col value]} ->
    ([tile row col value. tile]))

  (arr f32.mul : {(f32 value) (f32 value)} -> (f32 value))
  (arr f32.add : {(f32 value) (f32 value)} -> (f32 value))

  (def cooperative-global-to-shared :
    {
      ([.tile_num] extent value)
      (block value)
      (thread value)
      (([tile_num] index) value)
      (({f32 [tile_num] [tile_num]} gpu.global) value)
      (({f32 [tile_num] [tile_num]} gpu.global) value)
      (({f32 [tile_num] [tile_num]} gpu.shared) value)
      (({f32 [tile_num] [tile_num]} gpu.shared) value)
    } ->
    {
      (block value)
      (thread value)
      (([tile_num] index) value)
      (({f32 [tile_num] [tile_num]} gpu.global) value)
      (({f32 [tile_num] [tile_num]} gpu.global) value)
      (({f32 [tile_num] [tile_num]} gpu.shared) value)
      (({f32 [tile_num] [tile_num]} gpu.shared) value)
    }
    =
    {[n b t p global_a global_b tile_a tile_b.]
      ([.n t] thread.y [thread_y.])
      ([.n t] thread.x [thread_x.])
      ([.n b t] block.row [row.])
      ([.n b t] block.col [col.])

      # tile_A[thread.y, thread.x] = A[row, p * TILE + thread.x]
      ([.n p thread_x] p.tile-offset [a_col.])
      ([.global_a row a_col] gpu.global.load [a_val.])
      ([.tile_a thread_y thread_x a_val] gpu.shared.store [tile_a_loaded.])

      # tile_B[thread.y, thread.x] = B[p * TILE + thread.y, col]
      ([.n p thread_y] p.tile-offset [b_row.])
      ([.global_b b_row col] gpu.global.load [b_val.])
      ([.tile_b thread_y thread_x b_val] gpu.shared.store [tile_b_loaded.])

      ([.b t p global_a global_b tile_a_loaded tile_b_loaded])
    })

  (def q-loop.accumulate-dot :
    {
      ([.tile_num] extent value)
      (block value)
      (thread value)
      (({f32 [tile_num] [tile_num]} gpu.shared) value)
      (({f32 [tile_num] [tile_num]} gpu.shared) value)
      (f32 value)
    } ->
    {
      (block value)
      (thread value)
      (({f32 [tile_num] [tile_num]} gpu.shared) value)
      (({f32 [tile_num] [tile_num]} gpu.shared) value)
      (f32 value)
    }
    =
    {[n b t tile_a tile_b acc.]
      ([.n] value.type [tile_extent.])
      ([.tile_extent] extent.raw [tile_num.])
      ([.tile_extent] extent.index-type bound.eta [q_r q.])

      ([.n t] thread.y [thread_y.])
      ([.n t] thread.x [thread_x.])
      ([.tile_a thread_y q] gpu.shared.load [a_val.])
      ([.tile_b q thread_x] gpu.shared.load [b_val.])
      ([.a_val b_val] f32.mul [dot.])
      ([.] f32 bound.eta [acc_r acc_q.])
      ([.acc_q dot] f32.add [acc_next.])
      ([.n acc acc_r q_r acc_next] reduce-f32 [acc_out.])

      ([.b t tile_a tile_b acc_out])
    })
})

(theory control syntax {
  (arr sync : [x] -> [x])

  (def gpu.tiled_matmul :
    {
      ({({({block thread} product)
          ({f32 [tile_num] [tile_num]} gpu.shared)} product)
        ({f32 [tile_num] [tile_num]} gpu.shared)} product)
      ({({({block thread} product)
          ({f32 [tile_num] [tile_num]} gpu.shared)} product)
        ({f32 [tile_num] [tile_num]} gpu.shared)} product)
      ({({({block thread} product)
          ({f32 [tile_num] [tile_num]} gpu.shared)} product)
        ({f32 [tile_num] [tile_num]} gpu.shared)} product)
    } ->
    {
      ({({({block thread} product)
          ({f32 [tile_num] [tile_num]} gpu.shared)} product)
        ({f32 [tile_num] [tile_num]} gpu.shared)} product)
      ({({({block thread} product)
          ({f32 [tile_num] [tile_num]} gpu.shared)} product)
        ({f32 [tile_num] [tile_num]} gpu.shared)} product)
      ({({({block thread} product)
          ({f32 [tile_num] [tile_num]} gpu.shared)} product)
        ({f32 [tile_num] [tile_num]} gpu.shared)} product)
    }
    =
    {[entry sync_entry compute_entry.]
      ([.entry] sync [exit.])
      ([.exit sync_entry compute_entry])
    })
})
