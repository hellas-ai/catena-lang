# Catena-lang analogue of examples/puzzles/pooling.hex.
#
# This file declares the extra index/product/buffer primitives it needs locally,
# instead of extending catena-lang/stdlib/*.hex.
#
# It models the per-index pooling behavior:
#
#   output[0] = input[0]
#   output[1] = input[1] + input[0]
#   output[i] = input[i] + input[i - 1] + input[i - 2], for i >= 2
#
# Unlike the core example, this does not use gpu.global or gpu views. It uses a
# simple input/output buffers plus an index. The nested branch program computes
# the pooled value at that index; the store wrapper writes it to the output.
#
# NOTE: this is a language-level example. The current catena-lang HIP renderer
# does not yet lower these locally declared f32/index primitives.

(theory type nat {
  (arr ix.proof.zero : 1 -> 1)
  (arr ix.proof.nonzero : 1 -> 1)
  (arr ix.proof.one : 1 -> 1)
  (arr ix.proof.many : 1 -> 1)
})

(theory program type {
  # Local index primitives for this example.
  # Branch-producing predicates: the boolean controls `bool.ifc`, while the
  # proof tokens are threaded as branch environments.
  (arr ix.is-zero : {[n.]
    ([.n] ix val)
  } -> {[n.]
    (bool val)
    ([.n] ix.proof.zero)
    ([.n] ix.proof.nonzero)
  })
  (arr ix.is-one : {[n.]
    ([.n] ix val)
    ([.n] ix.proof.nonzero)
  } -> {[n.]
    (bool val)
    ([.n] ix.proof.one)
    ([.n] ix.proof.many)
  })
  (arr ix.pred : {[n proof.]
    ([.n] ix val)
    ([.proof])
  } -> {[n proof.]
    ([.n] ix val)
  })
  (def pool.payload.intro :
    {[n.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
    }
    ->
    {[n.]
      ({
        ({cap.ref [.n] f32} buf val)
        ([.n] ix val)
      } *)
    }
    =
    ([input index.]
      [.input index] * [payload.]
      [.payload]
    ))
  (def pool.payload.elim :
    {[n.]
      ({
        ({cap.ref [.n] f32} buf val)
        ([.n] ix val)
      } *)
    }
    ->
    {[n.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
    }
    =
    ([payload.]
      [.payload] * [input index.]
      [.input index]
    ))
  (arr f32.buf.store :
    {[n.]
      ({cap.own [.n] f32} buf val)
      ([.n] ix val)
      (f32 val)
    }
    ->
    {[n.]
      ({cap.own [.n] f32} buf val)
    })

  (def f32.pool-at-zero :
    {[n.]
      ([.n] ix.proof.zero)
      ({
        ({cap.ref [.n] f32} buf val)
        ([.n] ix val)
      } *)
    }
    ->
    {[n.] (f32 val)}
    =
    ([env payload.]
      [.payload] pool.payload.elim [input index.]
      [.index input] ix [current.]
      [.current]
    ))

  (def f32.pool-at-one :
    {[n.]
      ([.n] ix.proof.one)
      ({
        ({cap.ref [.n] f32} buf val)
        ([.n] ix val)
      } *)
    }
    ->
    {[n.] (f32 val)}
    =
    ([env payload.]
      [.payload] pool.payload.elim [input index.]
      [.index env] ix.pred [index_prev.]
      [.index input] ix [current.]
      [.index_prev input] ix [previous.]
      [.current previous] f32.add [sum.]
      [.sum]
    ))

  (def f32.pool-at-many :
    {[n.]
      ([.n] ix.proof.many)
      ({
        ({cap.ref [.n] f32} buf val)
        ([.n] ix val)
      } *)
    }
    ->
    {[n.] (f32 val)}
    =
    ([env payload.]
      [.payload] pool.payload.elim [input index.]
      [.index env] ix.pred [index_prev.]
      [.index_prev env] ix.pred [index_prev2.]
      [.index input] ix [current.]
      [.index_prev input] ix [previous.]
      [.index_prev2 input] ix [previous2.]
      [.current previous] f32.add [partial.]
      [.partial previous2] f32.add [sum.]
      [.sum]
    ))

})

(def program f32.pool-nonzero :
  {[n.]
    ([.n] ix.proof.nonzero)
    ({
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
    } *)
  }
  ->
  {[n.] (f32 val)}
  =
  ([env payload.]
    [.payload] pool.payload.elim [input index.]
    [.index env] ix.is-one [is_one one_case many_case.]
    {
      ([.input index] pool.payload.intro [payload_checked.])
      ([.is_one])
      ([.one_case])
      ([.many_case])
    }

    {
      [.one_case]
      name.f32.pool-at-one
      [.many_case]
      name.f32.pool-at-many
      [. is_one payload_checked]
    }
    bool.ifc
  )
)

(def program f32.pooling-last-three :
  {[n.]
    ({cap.ref [.n] f32} buf val)
    ({cap.own [.n] f32} buf val)
    ([.n] ix val)
  }
  ->
  {[n.]
    ({cap.own [.n] f32} buf val)
  }
  =
  ([input output index.]
    [.index] ix.is-zero [is_zero zero_case nonzero_case.]

    {
      ([.input index] pool.payload.intro [payload.])
      ([.is_zero])
      ([.zero_case])
      ([.nonzero_case])
    }

    # Outer if:
    #   if index == 0:
    #     input[index]
    #   else:
    #     run the nested non-zero decision above
    {
      [.zero_case]
      name.f32.pool-at-zero
      [.nonzero_case]
      name.f32.pool-nonzero
      [. is_zero payload]
    }
    bool.ifc [pooled.]

    [.output index pooled] f32.buf.store [output_pooled.]

    [.output_pooled]
  )
)
