# mems -> typed buffers -> row-major matrix views -> matmul -> materialized mem
(def program matmul-2x2-via-mem :
  ([n m k.] {
    (cap.ref mem)
    (cap.ref mem)
    ({[.n] u64} :)
    ({[.m] u64} :)
    ({[.k] u64} :)
    ({({[.n] [.k]} *) u64} :)
    ({({[.k] [.m]} *) u64} :)
    ({({[.n] [.m]} *) u64} :)
  })
  ->
  ([n m k.] (cap.own mem))
= ([a-mem b-mem n-len m-len k-len nk-len km-len nm-len.]
  ([.a-mem] mem.cast.f32 [actual-nk-len a-raw.]
    ([.b-mem] mem.cast.f32 [actual-km-len b-raw.]
      ([.nk-len actual-nk-len] u64.eq [a-len-eq if-a-len-eq _if-a-len-ne.]
        ([.km-len actual-km-len] u64.eq [b-len-eq if-b-len-eq _if-b-len-ne.]
          ({
            [.a-len-eq]
            [.if-a-len-eq]
          } assert-then [a-same-length.]
            ({
              [.b-len-eq]
              [.if-b-len-eq]
            } assert-then [b-same-length.]
              ({[.a-raw] [.a-same-length]} buf.f32.cast-same-length [a.]
                ({[.b-raw] [.b-same-length]} buf.f32.cast-same-length [b.]
                  ([.n-len] f32.matmul.len-copy-param [env-n producer-n.]
                    ([.m-len] f32.matmul.len-copy-param [env-m producer-m.]
                      ([.k-len] f32.matmul.len-copy-param [env-k producer-k.]
                        ([.nm-len] f32.matmul.len-copies3 [materialize-len mem-len split-index-len.]
                          ([.split-index-len] f32.matmul.len-copies2 [with-unit-len index-id-len.]
                            {
                              [.materialize-len]
                              ({
                                ({
                                  (([.with-unit-len] :.param) name.f32.matmul.index-with-unit lift)
                                  ({
                                    (({[.env-n]
                                      ({[.env-m]
                                        ({[.env-k]
                                          ({[.nk-len]
                                            ({[.km-len] ({[.a] [.b]} *.intro)} *.intro)
                                          } *.intro)
                                        } *.intro)
                                      } *.intro)
                                    } *.intro) defer)
                                    (([.index-id-len] :.param) name.f32.matmul.index-id lift)
                                  } tensor)
                                } compose)
                                ({[.producer-n] [.producer-m] [.producer-k]} name.test.matmul.two-bufs-at lift)
                              } compose)
                            }
                            materialize [result.]
                              {[.mem-len] [.result]} buf.to-mem)
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    )
  )
))

# mem -> typed buffer -> matrix view, multiplied by the shared identity view
(def program matmul-right-identity-2x2-via-mem :
  ([n.] {
    (cap.ref mem)
    ({[.n] u64} :)
    ({({[.n] [.n]} *) u64} :)
  })
  ->
  ([n.] (cap.own mem))
= ([a-mem n-len nn-len.]
  ([.a-mem] mem.cast.f32 [actual-nn-len a-raw.]
    ([.nn-len actual-nn-len] u64.eq [a-len-eq if-a-len-eq _if-a-len-ne.]
      ({
        [.a-len-eq]
        [.if-a-len-eq]
      } assert-then [a-same-length.]
        ({[.a-raw] [.a-same-length]} buf.f32.cast-same-length [a.]
          ([.n-len] f32.matmul.len-copy-param [env-n producer-n.]
            ([.nn-len] f32.matmul.len-split5 [env-nn materialize-len mem-len with-unit-len index-id-len _param.]
              {
                [.materialize-len]
                ({
                  ({
                    (([.with-unit-len] :.param) name.f32.matmul.index-with-unit lift)
                    ({
                      (({[.env-n] ({[.env-nn] [.a]} *.intro)} *.intro) defer)
                      (([.index-id-len] :.param) name.f32.matmul.index-id lift)
                    } tensor)
                  } compose)
                  ([.producer-n] name.test.matmul.right-identity-at lift)
                } compose)
              }
              materialize [result.]
                {[.mem-len] [.result]} buf.to-mem)
          )
        )
      )
    )
  )
))

# shared identity view multiplied by the matrix view derived from the input mem
(def program matmul-left-identity-2x2-via-mem :
  ([n.] {
    (cap.ref mem)
    ({[.n] u64} :)
    ({({[.n] [.n]} *) u64} :)
  })
  ->
  ([n.] (cap.own mem))
= ([a-mem n-len nn-len.]
  ([.a-mem] mem.cast.f32 [actual-nn-len a-raw.]
    ([.nn-len actual-nn-len] u64.eq [a-len-eq if-a-len-eq _if-a-len-ne.]
      ({
        [.a-len-eq]
        [.if-a-len-eq]
      } assert-then [a-same-length.]
        ({[.a-raw] [.a-same-length]} buf.f32.cast-same-length [a.]
          ([.n-len] f32.matmul.len-copy-param [env-n producer-n.]
            ([.nn-len] f32.matmul.len-split5 [env-nn materialize-len mem-len with-unit-len index-id-len _param.]
              {
                [.materialize-len]
                ({
                  ({
                    (([.with-unit-len] :.param) name.f32.matmul.index-with-unit lift)
                    ({
                      (({[.env-n] ({[.env-nn] [.a]} *.intro)} *.intro) defer)
                      (([.index-id-len] :.param) name.f32.matmul.index-id lift)
                    } tensor)
                  } compose)
                  ([.producer-n] name.test.matmul.left-identity-at lift)
                } compose)
              }
              materialize [result.]
                {[.mem-len] [.result]} buf.to-mem)
          )
        )
      )
    )
  )
))
(def program test.matmul.right-identity-at :
  ([n.] {
    ({
      ({[.n] u64} :)
      ({({({[.n] [.n]} *) u64} :) ({cap.ref ({[.n] [.n]} *) f32} buf val)} *)
    } *)
    (({[.n] [.n]} *) ix val)
  })
  ->
  ([n.] (f32 val))
= ([env flat.]
  ([.env] *.elim [n-len rest.]
    ([.rest] *.elim [nn-len a.]
      ([.n-len] f32.matmul.len-copies3 [identity-n view-rows split-view-n.]
        ([.split-view-n] f32.matmul.len-copies3 [view-cols generic-m generic-k.]
          ({
            [.generic-m]
            [.generic-k]
            ({[.view-rows] [.view-cols] ({[.nn-len] [.a]} f32.buf.view)} f32.row-major.matrix-view)
            ([.identity-n] f32.matrix.identity)
            [.flat]
          } f32.matmul.row-major.cell-at)
        )
      )
    )
  )
))

(def program test.matmul.left-identity-at :
  ([n.] {
    ({
      ({[.n] u64} :)
      ({({({[.n] [.n]} *) u64} :) ({cap.ref ({[.n] [.n]} *) f32} buf val)} *)
    } *)
    (({[.n] [.n]} *) ix val)
  })
  ->
  ([n.] (f32 val))
= ([env flat.]
  ([.env] *.elim [n-len rest.]
    ([.rest] *.elim [nn-len a.]
      ([.n-len] f32.matmul.len-copies3 [identity-n view-rows split-view-n.]
        ([.split-view-n] f32.matmul.len-copies3 [view-cols generic-m generic-k.]
          ({
            [.generic-m]
            [.generic-k]
            ([.identity-n] f32.matrix.identity)
            ({[.view-rows] [.view-cols] ({[.nn-len] [.a]} f32.buf.view)} f32.row-major.matrix-view)
            [.flat]
          } f32.matmul.row-major.cell-at)
        )
      )
    )
  )
))

(def program test.matmul.two-bufs-at :
  ([n m k.] {
    ({
      ({[.n] u64} :)
      ({
        ({[.m] u64} :)
        ({
          ({[.k] u64} :)
          ({
            ({({[.n] [.k]} *) u64} :)
            ({
              ({({[.k] [.m]} *) u64} :)
              ({
                ({cap.ref ({[.n] [.k]} *) f32} buf val)
                ({cap.ref ({[.k] [.m]} *) f32} buf val)
              } *)
            } *)
          } *)
        } *)
      } *)
    } *)
    (({[.n] [.m]} *) ix val)
  })
  ->
  ([n m k.] (f32 val))
= ([env flat.]
  ([.env] *.elim [n-len rest-a.]
    ([.rest-a] *.elim [m-len rest-b.]
      ([.m-len] f32.matmul.len-copies2 [generic-m view-m.]
        ([.rest-b] *.elim [k-len rest-c.]
          ([.k-len] f32.matmul.len-copies3 [generic-k a-k b-k.]
            ([.rest-c] *.elim [nk-len rest-d.]
              ([.rest-d] *.elim [km-len buffers.]
                ([.buffers] *.elim [a b.]
                  ({
                    [.generic-m]
                    [.generic-k]
                    ({[.n-len] [.a-k] ({[.nk-len] [.a]} f32.buf.view)} f32.row-major.matrix-view)
                    ({[.b-k] [.view-m] ({[.km-len] [.b]} f32.buf.view)} f32.row-major.matrix-view)
                    [.flat]
                  } f32.matmul.row-major.cell-at)
                )
              )
            )
          )
        )
      )
    )
  )
))
