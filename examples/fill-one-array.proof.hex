#
# Facts about the program user.f32.fill-one.
#
# Naming convention:
# - proof files mirror program files: fill-one-array.hex -> fill-one-array.proof.hex
# - facts use the program's full name plus SSA variable as a prefix:
#   user.f32.fill-one.<ssa-name>.<property>
# - fact order follows the program's SSA order.
#

(theory gpu.proof syntax {
  #
  # Program:
  #   ([.grid] gpu.grid.view [worker.])
  #
  # Fact: `worker` is the hierarchical worker-coordinate view for the grid.
  #
  #   gpu.ctx.grid(empty, grid, ([block_count] 1d), ([thread_count] 1d))
  #     |- worker : view(({([block_count] 1d) ([thread_count] 1d)} *))
  #
  # Derivation tree:
  #
  #   ----------------------------------------------------------- grid-view
  #    gpu.ctx.grid(empty, grid, ([block_count] 1d), ([thread_count] 1d))
  #      |- gpu.expr.grid-view(grid)
  #       : view(({([block_count] 1d) ([thread_count] 1d)} *))
  #
  (def user.f32.fill-one.worker.view :
    {gpu.ctx.empty [grid] ([block_count] 1d) ([thread_count] 1d)} ->
    ([grid block_count thread_count
      . grid block_count thread_count grid block_count thread_count]
      ({({gpu.ctx.empty [grid] ([block_count] 1d) ([thread_count] 1d)} gpu.ctx.grid)
        ([grid] gpu.expr.grid-view)
        (({([block_count] 1d) ([thread_count] 1d)} *) view)}
       |-)
    )
    = grid-view
  )

  #
  # Program:
  #   ([.worker] gpu.view.linearize [out_view.])
  #
  # Fact: `out_view` is in bounds for the output array.
  #
  #   Gamma |- out_view : view(([block_count * thread_count] 1d))
  #
  # Gamma records both the grid and the output global array.
  #
  #   ----------------------------------------------------------- global-linearize-1d-grid
  #    gpu.ctx.global(
  #      gpu.ctx.grid(empty, grid, ([block_count] 1d), ([thread_count] 1d)),
  #      out,
  #      block_count * thread_count,
  #      ([block_count * thread_count] 1d))
  #      |- gpu.expr.linearize(gpu.expr.grid-view(grid))
  #       : view(([block_count * thread_count] 1d))
  #
  (def user.f32.fill-one.out-view.view :
    ([grid block_count thread_count out . grid block_count thread_count]
      {gpu.ctx.empty [grid] ([block_count] 1d) ([thread_count] 1d)}) ->
    ([grid block_count thread_count out
      . grid block_count thread_count out block_count thread_count grid block_count thread_count]
      ({({({gpu.ctx.empty [grid] ([block_count] 1d) ([thread_count] 1d)} gpu.ctx.grid)
          [out]
          (({[block_count] [thread_count]} nat.mul) 1d)}
         gpu.ctx.global)
        (([grid] gpu.expr.grid-view) gpu.expr.linearize)
        ((({[block_count] [thread_count]} nat.mul) 1d) view)}
       |-)
    )
    = (
      user.f32.fill-one.worker.view
      global-linearize-1d-grid
    )
  )

  #
  # Program:
  #   ([.out out_view one] gpu.global.store [out_filled.])
  #
  # Fact: `out_filled` is produced by a global store whose view is in bounds
  # for `out`.
  #
  # This fact uses user.f32.fill-one.out-view.view as a lemma.
  #
  # Derivation tree:
  #
  #    Gamma |- gpu.expr.linearize(gpu.expr.grid-view(grid))
  #          : view(([block_count * thread_count] 1d))
  #   -------------------------------------------------------------- global-store
  #  Gamma |- global.store(out, linearize(grid.view(grid)), one)
  #        : view(([block_count * thread_count] 1d))
  #
  (def user.f32.fill-one.out-filled.store-view :
    ([grid block_count thread_count out one . grid block_count thread_count]
      {gpu.ctx.empty [grid] ([block_count] 1d) ([thread_count] 1d)}) ->
    ([grid block_count thread_count out one
      . grid block_count thread_count out block_count thread_count out grid one block_count thread_count]
      ({({({gpu.ctx.empty [grid] ([block_count] 1d) ([thread_count] 1d)} gpu.ctx.grid)
          [out]
          (({[block_count] [thread_count]} nat.mul) 1d)}
         gpu.ctx.global)
        ({[out] (([grid] gpu.expr.grid-view) gpu.expr.linearize) [one]} gpu.expr.global.store)
        ((({[block_count] [thread_count]} nat.mul) 1d) view)}
       |-)
    )
    = (
      user.f32.fill-one.out-view.view
      global-store
    )
  )
})
