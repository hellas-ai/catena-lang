# Example entrypoint for row-major f32 matrix multiplication.
#
# The reusable implementation lives in stdlib/matrix.hex. It builds buffer
# reader closures in the outer layer, converts flat row-major output indices to
# (row, col), and computes each output cell as:
#
#   C[i,j] = sum_k A[i,k] * B[k,j]
(def program f32.matmul.row-major-bufs-example :
  ([n m k.] {
    ({[.n] u64} :)
    ({[.m] u64} :)
    ({[.k] u64} :)
    ({({[.n] [.k]} *) u64} :)
    ({({[.k] [.m]} *) u64} :)
    ({({[.n] [.m]} *) u64} :)
    ({cap.ref ({[.n] [.k]} *) f32} buf val)
    ({cap.ref ({[.k] [.m]} *) f32} buf val)
  })
  ->
  ([n m k.] ({cap.own ({[.n] [.m]} *) f32} buf val))
= f32.matmul.row-major-bufs)
