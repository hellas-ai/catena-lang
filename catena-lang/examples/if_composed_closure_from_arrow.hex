(def program f32.id : (f32 val) -> (f32 val) = [x])

# Helper with closure-typed boundaries. The CLI inlines this before rejecting
# closure-typed public interfaces, so the public example below stays valid.
# It consumes two f32 closures and returns a closure that composes them.
(def program compose-f32-closures :
  {({(f32 val) (f32 val)} =>) ({(f32 val) (f32 val)} =>)}
  ->
  ({(f32 val) (f32 val)} =>)
= compose)

# bool.if consumes two distinct closures:
#
#   name.f32.id  lift -.
#                    compose-f32-closures -> first closure  -.
#   name.f32.neg lift -'                                  bool.if
#   name.f32.id  lift ------------------> second closure -'
#
# The first closure is not produced directly by lift/defer. It is the result of
# calling an arrow that takes two closures and returns a combined closure.
(def program if-composed-closure-from-arrow : {(bool val) (f32 val)} -> (f32 val) = ([b x.]
  {
    ({(name.f32.id lift) (name.f32.neg lift)} compose-f32-closures)
    (name.f32.id lift)
    [.b]
    [.x]
  }
  bool.if
))
