      "updated": 1780301113825,
      "link": null,
      "locked": false,
      "text": "observations\n- a flowchart is a sort of hierarchical hypergraph. A block is actually a data hypergraph while wiring is control\n- a data hypergraph can be mapped to a control hypergraph fixing a topological ordering for the execution",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "observations\n- a flowchart is a sort of hierarchical hypergraph. A block is actually a data hypergraph while wiring is control\n- a data hypergraph can be mapped to a control hypergraph fixing a topological ordering for the execution",
      "autoResize": true,
      "lineHeight": 1.25
    }
