  (arr name.ax-mp : [x0 x1 . x0 x1] -> ([x0 x1 . x0 x1 x0 x1] {({[ph ps . ] ([ . ph] |-) ([ . ph ps] ==> |-)} *) (([ph ps . ps] |-) [x0 . x0])} -> val))
  (arr name.bool.and : [] -> ([] {({(bool val) (bool val)} *) ((bool val) [x0 . x0])} -> val))
  (arr name.bool.copy : [] -> ([] {((bool val) [x0 . x0]) ({(bool val) (bool val)} *)} -> val))
  (arr name.bool.f : [] -> ([] {([] 1) ((bool val) [x0 . x0])} -> val))
  (arr name.bool.id : [] -> ([] {((bool val) [x0 . x0]) ((bool val) [x0 . x0])} -> val))
  (arr name.bool.if : [x0 x1 . x0 x1] -> ([x0 x1 . x0 x1 x0 x1] {({bool (=> val)} *) ((=> val) [x0 . x0])} -> val))
  (arr name.bool.ifc : [x0 x1 x2 x3 . x0 x1 x2 x3] -> ([x0 x1 x2 x3 . x0 x1 x2 x3 x0 x1 x2 x3] {({[x y a b . ] ([ . x]) ([ . x a] {* [ . b]} -> val) ([ . y]) ([ . y a] {* [ . b]} -> val) (bool val) ([ . a])} ({({({({* [x2 . x2]} *) [x3 . x3]} *) [x4 . x4]} *) [x5 . x5]} *)) (([x y a b . b]) [x0 . x0])} -> val))
  (arr name.bool.li : [] -> ([] {((bool val) [x0 . x0]) ({1 (bool val)} *)} -> val))
  (arr name.bool.not : [] -> ([] {((bool val) [x0 . x0]) ((bool val) [x0 . x0])} -> val))
  (arr name.bool.or : [] -> ([] {({(bool val) (bool val)} *) ((bool val) [x0 . x0])} -> val))
  (arr name.bool.t : [] -> ([] {([] 1) ((bool val) [x0 . x0])} -> val))
  (arr name.bool.type : [] -> ([] {([] 1) (bool [x0 . x0])} -> val))
  (arr name.buf.to-mem : [x0 x1 x2 . x0 x1 x2] -> ([x0 x1 x2 . x0 x1 x2 x0 x1 x2] {({[m n t . ] ({[ . n] u64} :) ([ . m n t] buf val)} *) (([m n t . m] mem) [x0 . x0])} -> val))
  (arr name.compose : [x0 x1 x2 . x0 x1 x2] -> ([x0 x1 x2 . x0 x1 x2 x0 x1 x2] {({[a b c . ] ([ . a b] =>) ([ . b c] =>)} *) (([a b c . a c] =>) [x0 . x0])} -> val))
  (arr name.defer : [x0 . x0] -> ([x0 . x0 x0] {([a . a] [x0 . x0]) (({1 [a . a]} =>) [x0 . x0])} -> val))
  (arr name.f32.add : [] -> ([] {({(f32 val) (f32 val)} *) ((f32 val) [x0 . x0])} -> val))
  (arr name.f32.buf.drop : [] -> ([] {(({cap.own u64 f32} buf val) [x0 . x0]) ([] 1)} -> val))
  (arr name.f32.buf.load : [] -> ([] {({({cap.own u64 f32} buf val) (u64 ix val)} *) ({({cap.own u64 f32} buf val) (f32 val)} *)} -> val))
  (arr name.f32.buf.store : [] -> ([] {({({cap.own u64 f32} buf val) (u64 ix val) (f32 val)} ({* [x2 . x2]} *)) (({cap.own u64 f32} buf val) [x0 . x0])} -> val))
  (arr name.f32.pool-at-many : [] -> ([] {({1 ({({cap.own u64 f32} buf val) (u64 ix val)} *)} *) ((f32 val) [x0 . x0])} -> val))
  (arr name.f32.pool-at-one : [] -> ([] {({1 ({({cap.own u64 f32} buf val) (u64 ix val)} *)} *) ((f32 val) [x0 . x0])} -> val))
  (arr name.f32.pool-at-zero : [] -> ([] {({1 ({({cap.own u64 f32} buf val) (u64 ix val)} *)} *) ((f32 val) [x0 . x0])} -> val))
