# Closure-conversion-v2 examples.
#
# These definitions deliberately stop at ordinary closure-using operations.  The
# forget_closures pass bends the CMC wiring and inserts one !closure edge at each
# place where a non-CMC operation observes a closure.  Closure conversion v2 can
# then discover a region by walking backwards from the first !closure input and
# forwards again until it reaches the second input.

# 1. Closed closures made from names.  The region contains the name's function
# pointer and the eval introduced by forget_closures, but has no captured value.
(def program closure2-named-if :
  {(bool val) (bool val)}
  ->
  (bool val)
= ([flag argument.]
  {(name.bool.not lift) (name.bool.id lift) [.flag argument]}
  bool.if
))

# 2. The smallest captured environments.  Each branch captures one runtime
# value and has unit as its closure domain.
(def program closure2-captured-if :
  {(bool val) (bool val) (bool val)}
  ->
  (bool val)
= ([lhs rhs flag.]
  {([.lhs] defer) ([.rhs] defer) [.flag] unit.intro}
  bool.if
))

# 3. A multi-edge region.  The captured value is deferred and then flows through
# a lifted named operation before reaching the !closure boundary.
(def program closure2-composed-if :
  {(bool val) (bool val) (bool val)}
  ->
  (bool val)
= ([lhs rhs flag.]
  {
    ({([.lhs] defer) (name.bool.not lift)} compose)
    ({([.rhs] defer) (name.bool.id lift)} compose)
    [.flag]
    unit.intro
  }
  bool.if
))

# 4. Parallel control flow inside one closure.  tensor combines two independently
# captured values into a single closure whose domain and codomain are products.
(def program closure2-tensored-if :
  {(bool val) (bool val) (bool val)}
  ->
  ({(bool val) (bool val)} *)
= ([lhs rhs flag.]
  {
    ({([.lhs] defer) ([.rhs] defer)} tensor)
    ({(bool.f defer) (bool.t defer)} tensor)
    [.flag]
    ({unit.intro unit.intro} *.intro)
  }
  bool.if
))

# 5. A closure below a product boundary.  The consumer is deliberately a
# definition rather than a primitive: because its boundary contains a closure,
# the early inline pass expands it before forget_closures.  This leaves the
# structural *.intro/*.elim pair around the closure available for inspecting
# how forget_closures treats product structure.
(def program closure2.consume-packed :
  ({({1 (bool val)} =>) (bool val)} *)
  ->
  (bool val)
= ([packed.]
  ([.packed] *.elim [function payload.])
  {([.function] run) [.payload]}
  bool.and
))

(def program closure2-packed-closure :
  {(bool val) (bool val)}
  ->
  (bool val)
= ([captured payload.]
  {([.captured] defer) [.payload]}
  *.intro
  closure2.consume-packed
))

# 6. Two closures pass through an explicit product round trip before becoming
# the two branches of a closure-consuming primitive.  This makes both sides of
# the structural boundary visible: *.intro consumes two closure wires, while
# *.elim emits the same two closure wires for bool.if.
(def program closure2-packed-if :
  {(bool val) (bool val) (bool val)}
  ->
  (bool val)
= ([lhs rhs flag.]
  ({([.lhs] defer) ([.rhs] defer)} *.intro [packed.])
  ([.packed] *.elim [true-branch false-branch.])
  {[.true-branch] [.false-branch] [.flag] unit.intro}
  bool.if
))

# 7. Two unrelated closure regions at one operation, including a product domain
# and a domain whose type depends on the ambient reduction length.
(def program closure2-u64-one-at :
  ([n.] ([.n] ix val))
  ->
  ([n.] (u64 val))
= ([i.] u64.one))

(def program closure2-reduce :
  []
  ->
  (u64 val)
= (
  {
    const.u64.0x0000000000000000
    (name.u64.add lift)
    ((u64.zero :.param) name.closure2-u64-one-at lift)
    u64.zero
  }
  reduce
))

# 8. A minimal closure-only matmul kernel: compute one dot product from two
# indexed f32 closures.  It knows nothing about buffers or how either closure
# was constructed.
# id(p) = p
(def program closure2.index-id :
  ([n.] ([.n] ix val))
  ->
  ([n.] ([.n] ix val))
= [i])

# copy(p) = (p,p)
(def program closure2.index-copy :
  ([n.] ([.n] ix val))
  ->
  ([n.] {([.n] ix val) ([.n] ix val)})
= [i . i i])

# flat-copy(p) = (p,p)
(def program closure2.matrix-flat-copy :
  ([n m.] (({[.n] [.m]} *) ix val))
  ->
  ([n m.] {
    (({[.n] [.m]} *) ix val)
    (({[.n] [.m]} *) ix val)
  })
= [i . i i])

# with-unit(p) = (unit,p)
(def program closure2.index-with-unit :
  ([n.] ([.n] ix val))
  ->
  ([n.] {1 ([.n] ix val)} *)
= ([i.] {unit.intro [.i]} *.intro))

# buf-at(buffer,p) = buffer[p]
(def program closure2.f32-buf-at :
  ([n.] {
    ({cap.ref [.n] f32} buf val)
    ([.n] ix val)
  })
  ->
  ([n.] (f32 val))
= ([input i.]
  {[.i input]} ix
))

# buf-view(buffer)(p) = buffer[p]
# Turn a buffer into an indexed closure.  This construction stays at the outer
# layer; closure2.matmul-dot below receives only the resulting closure.
(def program closure2.f32-buf-view :
  ([n.] {
    ({[.n] u64} :)
    ({cap.ref [.n] f32} buf val)
  })
  ->
  ([n.] ({([.n] ix val) (f32 val)} =>))
= ([len input.]
  {
    ({
      (([.len] :.param) name.closure2.index-with-unit lift)
      ({
        ([.input] defer)
        (([.len] :.param) name.closure2.index-id lift)
      } tensor)
    } compose)
    (([.len] :.param) name.closure2.f32-buf-at lift)
  }
  compose
))

# dot(left,right) = sum_{p=0}^{k-1} left(p)*right(p)
(def program closure2.matmul-dot :
  ([k.] {
    ({[.k] u64} :)
    ({([.k] ix val) (f32 val)} =>)
    ({([.k] ix val) (f32 val)} =>)
  })
  ->
  ([k.] (f32 val))
= ([len left right.]
  {
    (const.u32.0x00000000 u32.bitcast-f32)
    (name.f32.add lift)
    ({
      ({
        (([.len] :.param) name.closure2.index-copy lift)
        ({[.left] [.right]} tensor)
      } compose)
      (name.f32.mul lift)
    } compose)
    [.len]
  }
  reduce
))

# Minimal row-major index primitives used only to turn flat buffer views into
# matrix views.  Their formulas are included here so the examples remain
# readable without importing the branch's matrix library.
(theory program type {
  # flat(m, i, j) = i*m + j
  (arr closure2.row-major-index :
    ([n m.] {
      ({[.m] u64} :)
      ({([.n] ix val) ([.m] ix val)} *)
    })
    ->
    ([n m.] (({[.n] [.m]} *) ix val)))

  # row(m, flat) = floor(flat/m)
  (arr closure2.row-major-row :
    ([n m.] {
      ({[.m] u64} :)
      (({[.n] [.m]} *) ix val)
    })
    ->
    ([n m.] ([.n] ix val)))

  # col(m, flat) = flat mod m
  (arr closure2.row-major-col :
    ([n m.] {
      ({[.m] u64} :)
      (({[.n] [.m]} *) ix val)
    })
    ->
    ([n m.] ([.m] ix val)))
})

# id(i,j) = (i,j)
(def program closure2.matrix-index-id :
  ([n m.] {([.n] ix val) ([.m] ix val)} *)
  ->
  ([n m.] {([.n] ix val) ([.m] ix val)} *)
= [ij])

# with-unit(i,j) = (unit,(i,j))
(def program closure2.matrix-index-with-unit :
  ([n m.] {([.n] ix val) ([.m] ix val)} *)
  ->
  ([n m.] {1 ({([.n] ix val) ([.m] ix val)} *)} *)
= ([ij.] {unit.intro [.ij]} *.intro))

# view(i,j) = flat-view(i*m + j)
(def program closure2.row-major-matrix-view :
  ([n m.] {
    ({[.n] u64} :)
    ({[.m] u64} :)
    ({(({[.n] [.m]} *) ix val) (f32 val)} =>)
  })
  ->
  ([n m.] ({({([.n] ix val) ([.m] ix val)} *) (f32 val)} =>))
= ([rows cols flat-view.]
  {
    ({
      ({
        ({
          ({([.rows] :.param) ([.cols] :.param)}
            name.closure2.matrix-index-with-unit lift)
          ({
            ([.cols] defer)
            ({([.rows] :.param) ([.cols] :.param)}
              name.closure2.matrix-index-id lift)
          } tensor)
        } compose)
        ({([.rows] :.param) ([.cols] :.param)}
          name.closure2.row-major-index lift)
      } compose)
      [.flat-view]
    } compose)
  }
))

# row(A,i)(p) = A(i,p)
(def program closure2.matrix-row :
  ([n k.] {
    ({[.k] u64} :)
    ({({([.n] ix val) ([.k] ix val)} *) (f32 val)} =>)
    ([.n] ix val)
  })
  ->
  ([n k.] ({([.k] ix val) (f32 val)} =>))
= ([len matrix i.]
  ({
    ({
      (([.len] :.param) name.closure2.index-with-unit lift)
      ({
        ([.i] defer)
        (([.len] :.param) name.closure2.index-id lift)
      } tensor)
    } compose)
    [.matrix]
  } compose)
))

# with-unit-right(p) = (p,unit)
(def program closure2.index-with-unit-right :
  ([n.] ([.n] ix val))
  ->
  ([n.] {([.n] ix val) 1} *)
= ([i.] {[.i] unit.intro} *.intro))

# col(B,j)(p) = B(p,j)
(def program closure2.matrix-col :
  ([k m.] {
    ({[.k] u64} :)
    ({({([.k] ix val) ([.m] ix val)} *) (f32 val)} =>)
    ([.m] ix val)
  })
  ->
  ([k m.] ({([.k] ix val) (f32 val)} =>))
= ([len matrix j.]
  ({
    ({
      (([.len] :.param) name.closure2.index-with-unit-right lift)
      ({
        (([.len] :.param) name.closure2.index-id lift)
        ([.j] defer)
      } tensor)
    } compose)
    [.matrix]
  } compose)
))

# C(i,j) = sum_{p=0}^{k-1} A(i,p) * B(p,j)
(def program closure2.matmul-cell :
  ([n m k.] {
    ({[.k] u64} :)
    ({({([.n] ix val) ([.k] ix val)} *) (f32 val)} =>)
    ({({([.k] ix val) ([.m] ix val)} *) (f32 val)} =>)
    ([.n] ix val)
    ([.m] ix val)
  })
  ->
  ([n m k.] (f32 val))
= ([len left right i j.]
  {
    [.len]
    ({[.len] [.left] [.i]} closure2.matrix-row)
    ({[.len] [.right] [.j]} closure2.matrix-col)
  }
  closure2.matmul-dot
))

# A(i,j) = left-buffer[i*k+j], B(i,j) = right-buffer[i*m+j],
# result = C(i,j) = sum_p A(i,p)*B(p,j)
(def program closure2.matmul-cell-two-bufs :
  ([n m k.] {
    ({[.n] u64} :)
    ({[.m] u64} :)
    ({[.k] u64} :)
    ({({[.n] [.k]} *) u64} :)
    ({({[.k] [.m]} *) u64} :)
    ({cap.ref ({[.n] [.k]} *) f32} buf val)
    ({cap.ref ({[.k] [.m]} *) f32} buf val)
    ([.n] ix val)
    ([.m] ix val)
  })
  ->
  ([n m k.] (f32 val))
= ([rows cols inner left-size right-size left-buffer right-buffer i j.]
  {
    [.inner]
    ({
      [.rows]
      [.inner]
      ({[.left-size] [.left-buffer]} closure2.f32-buf-view)
    } closure2.row-major-matrix-view)
    ({
      [.inner]
      [.cols]
      ({[.right-size] [.right-buffer]} closure2.f32-buf-view)
    } closure2.row-major-matrix-view)
    [.i]
    [.j]
  }
  closure2.matmul-cell
))

# I(i,j) = 1 when i=j and 0 otherwise.
(def program closure2.f32-identity-at :
  ([n.] {([.n] ix val) ([.n] ix val)} *)
  ->
  ([n.] (f32 val))
= ([ij.]
  ([.ij] *.elim [i j.]
    ([.i] ix.to-u64 [i-u64.]
      ([.j] ix.to-u64 [j-u64.]
        ({[.i-u64 j-u64]} u64.ne [different.]
          ([.different] bool.not [same.]
            {[.same] f32.one (const.u32.0x00000000 u32.bitcast-f32)}
            f32.select
          )
        )
      )
    )
  )
))

# A(i,j) = input-buffer[i*n+j], B = I,
# result = C(i,j) = sum_p A(i,p)*I(p,j)
(def program closure2.matmul-cell-buf-and-identity :
  ([n.] {
    ({[.n] u64} :)
    ({({[.n] [.n]} *) u64} :)
    ({cap.ref ({[.n] [.n]} *) f32} buf val)
    ([.n] ix val)
    ([.n] ix val)
  })
  ->
  ([n.] (f32 val))
= ([size flat-size input i j.]
  {
    [.size]
    ({
      [.size]
      [.size]
      ({[.flat-size] [.input]} closure2.f32-buf-view)
    } closure2.row-major-matrix-view)
    (([.size] :.param) name.closure2.f32-identity-at lift)
    [.i]
    [.j]
  }
  closure2.matmul-cell
))

# two-bufs-at(env,flat) = C(row(flat),col(flat))
(def program closure2.matmul-two-bufs-at : ([n m k . ] {({({[ . n] u64} :) ({({[ . m] u64} :) ({({[ . k] u64} :) ({({({[ . n] [ . k]} *) u64} :) ({({({[ . k] [ . m]} *) u64} :) ({({cap.ref ({[ . n] [ . k]} *) f32} buf val) ({cap.ref ({[ . k] [ . m]} *) f32} buf val)} *)} *)} *)} *)} *)} *) (({[ . n] [ . m]} *) ix val)}) -> ([n m k . ] (f32 val)) = ([env flat . ] ([ . env] *.elim [rows rest-a . ] ([ . rest-a] *.elim [cols rest-b . ] ([ . rest-b] *.elim [inner rest-c . ] ([ . rest-c] *.elim [left-size rest-d . ] ([ . rest-d] *.elim [right-size buffers . ] ([ . buffers] *.elim [left-buffer right-buffer . ] ([ . flat] closure2.matrix-flat-copy [flat-row flat-col . ] ({[ . cols] [ . flat-row]} closure2.row-major-row [i . ] ({[ . cols] [ . flat-col]} closure2.row-major-col [j . ] {[ . rows] [ . cols] [ . inner] [ . left-size] [ . right-size] [ . left-buffer] [ . right-buffer] [ . i] [ . j]} closure2.matmul-cell-two-bufs)))))))))))

# matmul-two-bufs(A,B)[flat] = sum_p A(row(flat),p)*B(p,col(flat))
(def program closure2.matmul-two-bufs : ([n m k . ] {({[ . n] u64} :) ({[ . m] u64} :) ({[ . k] u64} :) ({({[ . n] [ . k]} *) u64} :) ({({[ . k] [ . m]} *) u64} :) ({({[ . n] [ . m]} *) u64} :) ({cap.ref ({[ . n] [ . k]} *) f32} buf val) ({cap.ref ({[ . k] [ . m]} *) f32} buf val)}) -> ([n m k . ] ({cap.own ({[ . n] [ . m]} *) f32} buf val)) = ([rows cols inner left-size right-size output-size left-buffer right-buffer . ] {({[ . rows] ({[ . cols] ({[ . inner] ({[ . left-size] ({[ . right-size] ({[ . left-buffer] [ . right-buffer]} *.intro)} *.intro)} *.intro)} *.intro)} *.intro)} *.intro) ({([ . rows] :.param) ([ . cols] :.param) ([ . inner] :.param)} name.closure2.matmul-two-bufs-at) [ . output-size]} materializec))

# buf-identity-at(env,flat) = sum_p A(row(flat),p)*I(p,col(flat))
(def program closure2.matmul-buf-identity-at : ([n . ] {({({[ . n] u64} :) ({({({[ . n] [ . n]} *) u64} :) ({cap.ref ({[ . n] [ . n]} *) f32} buf val)} *)} *) (({[ . n] [ . n]} *) ix val)}) -> ([n . ] (f32 val)) = ([env flat . ] ([ . env] *.elim [size rest . ] ([ . rest] *.elim [flat-size input . ] ([ . flat] closure2.matrix-flat-copy [flat-row flat-col . ] ({[ . size] [ . flat-row]} closure2.row-major-row [i . ] ({[ . size] [ . flat-col]} closure2.row-major-col [j . ] {[ . size] [ . flat-size] [ . input] [ . i] [ . j]} closure2.matmul-cell-buf-and-identity)))))))

# matmul-buf-identity(A)[flat] = sum_p A(row(flat),p)*I(p,col(flat))
(def program closure2.matmul-buf-and-identity : ([n . ] {({[ . n] u64} :) ({({[ . n] [ . n]} *) u64} :) ({cap.ref ({[ . n] [ . n]} *) f32} buf val)}) -> ([n . ] ({cap.own ({[ . n] [ . n]} *) f32} buf val)) = ([size flat-size input . ] {({[ . size] ({[ . flat-size] [ . input]} *.intro)} *.intro) (([ . size] :.param) name.closure2.matmul-buf-identity-at) [ . flat-size]} materializec))
