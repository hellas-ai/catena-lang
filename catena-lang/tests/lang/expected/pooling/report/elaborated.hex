  (arr name.f32.pool.payload.intro : [] -> ([] {({({cap.own u64 f32} buf val) (u64 ix val)} *) (({({cap.own u64 f32} buf val) (u64 ix val)} *) [x0 . x0])} -> val))
  (arr name.f32.pooling-last-three-at : [] -> ([] {({(bool val) (bool val) ({({cap.own u64 f32} buf val) (u64 ix val)} *)} ({* [x2 . x2]} *)) ((f32 val) [x0 . x0])} -> val))
  (arr name.f32.pooling-last-three-store : [] -> ([] {({({cap.own u64 f32} buf val) ({cap.own u64 f32} buf val) (u64 ix val)} ({* [x2 . x2]} *)) (({cap.own u64 f32} buf val) [x0 . x0])} -> val))
