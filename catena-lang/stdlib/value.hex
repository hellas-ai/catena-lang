# basic datatypes
(theory type nat {
  # anonymous runtime values.
  # val(t) ~= "a runtime value of type t"
  (arr val : 1 -> 1)

  # value ascription
  #   x : t
  # x is the type-level name of a runtime value with type t.
  (arr :   : 2 -> 1)

  # provability
  (arr |- : 1 -> 1)

  # implication
  (arr ==> : 2 -> 1)

  # Equality
  (arr = : 2 -> 1)

  # negation
  (arr not : 1 -> 1)
})

(theory program type {
  (arr :.forget : : -> ([x t.t] val))
  (arr :.param : : -> [x t . x])
  (arr :.ty : : -> {({[.x] [.t]} :) [x t . x]})

  # Modus ponens:
  #   h0 : |- φ
  #   h1 : |- φ → ψ
  # ----------------
  #   r0 : |- ψ
  (arr ax-mp : {[ph ps.] # two metavars
    ([.ph] |-)            # |- φ
    ([.ph ps] ==> |-)      # |- (φ → ψ)
  } -> ([ph ps . ps] |-)) # |- ψ
})

# Exact-arity structural helpers for typed `u64` values. Their definitions perform
# contraction at the wire level through `:.ty`; callers receive distinct value
# wires and request no surplus runtime outputs.
(def program u64.copies2 :
  ([x.] ({[.x] u64} :))
  ->
  ([x.] {({[.x] u64} :) ({[.x] u64} :)})
= ([value.]
  ([.value] :.ty [copy-a _param-a.]
    ([.copy-a] :.ty [copy-b _param-b.]
      {[.copy-a] [.copy-b]}
    )
  )
))

(def program u64.copies3 :
  ([x.] ({[.x] u64} :))
  ->
  ([x.] {({[.x] u64} :) ({[.x] u64} :) ({[.x] u64} :)})
= ([value.]
  ([.value] :.ty [copy-a _param-a.]
    ([.copy-a] :.ty [copy-b _param-b.]
      ([.copy-b] :.ty [copy-c _param-c.]
        {[.copy-a] [.copy-b] [.copy-c]}
      )
    )
  )
))

(def program u64.copies6 :
  ([x.] ({[.x] u64} :))
  ->
  ([x.] {
    ({[.x] u64} :)
    ({[.x] u64} :)
    ({[.x] u64} :)
    ({[.x] u64} :)
    ({[.x] u64} :)
    ({[.x] u64} :)
  })
= ([value.]
  ([.value] :.ty [copy-a _param-a.]
    ([.copy-a] :.ty [copy-b _param-b.]
      ([.copy-b] :.ty [copy-c _param-c.]
        ([.copy-c] :.ty [copy-d _param-d.]
          ([.copy-d] :.ty [copy-e _param-e.]
            ([.copy-e] :.ty [copy-f _param-f.]
              {[.copy-a] [.copy-b] [.copy-c] [.copy-d] [.copy-e] [.copy-f]}
            )
          )
        )
      )
    )
  )
))

(def program u64.copies2-param :
  ([x.] ({[.x] u64} :))
  ->
  ([x.] {({[.x] u64} :) ({[.x] u64} :) [.x]})
= ([value.]
  ([.value] :.ty [copy-a param.]
    ([.copy-a] :.ty [copy-b _param-b.]
      {[.copy-a] [.copy-b] [.param]}
    )
  )
))

(def program u64.copy-param :
  ([x.] ({[.x] u64} :))
  ->
  ([x.] {({[.x] u64} :) [.x]})
= ([value.]
  ([.value] :.ty [copy param.] {[.copy] [.param]})
))

(def program u64.params3 :
  ([x.] ({[.x] u64} :))
  ->
  ([x.] {[.x] [.x] [.x]})
= ([value.]
  {([.value] :.param) ([.value] :.param) ([.value] :.param)}
))

(def program u64.copy-params3 :
  ([x.] ({[.x] u64} :))
  ->
  ([x.] {({[.x] u64} :) [.x] [.x] [.x]})
= ([value.]
  ([.value] :.ty [copy-a param-a.]
    ([.copy-a] :.ty [copy-b param-b.]
      ([.copy-b] :.ty [copy-c param-c.]
        {[.copy-c] [.param-a] [.param-b] [.param-c]}
      )
    )
  )
))
