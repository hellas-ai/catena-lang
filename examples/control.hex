#
# Control Flow Theory
#

# shared syntax

### Primitive type
(object f32 : 0 -> 1)
(object bool : 0 -> 1)

### Type constructors
(object product : 2 -> 1)
(object unit : 0 -> 1)
(object coproduct : 2 -> 1)
(object counit : 0 -> 1)

### Cartesian CoMonoidal Category

(arrow merge : [x . x x] -> [x])
(arrow create : [x.] -> [x])
(arrow branch : [x] -> [x . x x])
(arrow discard : [x] -> [x.])
(arrow guard : ({bool [x]} product) -> [x . x x])

### Programs

(def-arrow guarded-positive-update :
  ({f32 f32} product) ->
  {({f32 f32} product) ({f32 f32} product)}
  =
  (
    data.copy
    data.any-positive.bind
    guard
    {data.add-one-second data.add-one-first}
  ))
