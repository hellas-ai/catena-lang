#
# Data Flow Theory
#

# shared syntax

### Primitive type
(object f32 : 0 -> 1)
(object bool : 0 -> 1)

### Arithmetics
(arrow f32.zero : [] -> f32)
(arrow f32.one : [] -> f32)
(arrow f32.add : {f32 f32} -> f32)
(arrow bool.gt : {f32 f32} -> bool)
(arrow bool.or : {bool bool} -> bool)

### Type constructors
(object product : 2 -> 1)
(object unit : 0 -> 1)
(object coproduct : 2 -> 1)
(object counit : 0 -> 1)

### Cartesian Monoidal Category

(arrow copy :  [x] -> [x . x x])
(arrow discard :  [x] -> [x.])

(def-arrow projl : [x y] -> [x y . x] = {[x] discard})
(def-arrow projr : [x y] -> [x y . y] = {discard [y]})

### Programs

(def-arrow any-positive : {f32 f32} -> bool =
  ({
    ({[x] f32.zero} bool.gt)
    ({[y] f32.zero} bool.gt)
  } bool.or))

(def-arrow any-positive.bind : {f32 f32 [x]} -> {bool [x]} =
  {[a b x.]
    ([.a b] any-positive [condition.])
    ([.condition x])
  })

(def-arrow add-one-first : {f32 f32} -> {f32 f32} =
  {
    ({[x] f32.one} f32.add)
    [y]
  })

(def-arrow add-one-second : {f32 f32} -> {f32 f32} =
  {
    [x]
    ({[y] f32.one} f32.add)
  })
