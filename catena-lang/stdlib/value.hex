# basic datatypes
(theory type nat {
  # anonymous runtime values.
  # val(t) ~= "a runtime value of type t"
  (arr val : 1 -> 1)

  # value ascription
  #   x : t
  # x is the type-level name of a runtime value with type t.
  (arr :   : 2 -> 1)

  # type witness for an object
  (arr ty : 1 -> 1)

  # provability
  (arr |- : 1 -> 1)

  # implication
  (arr ==> : 2 -> 1)

  # Equality
  (arr = : 2 -> 1)

  # negation
  (arr not : 1 -> 1)
})

(theory program type {
  (arr :.forget : : -> ([x t.t] val))
  (arr :.param : : -> [x t . x])
  (arr :.copy : ([x t.] ({[.x t]} :)) -> ([x t.] {({[.x t]} :) ({[.x t]} :)}))
  (arr :.ty : : -> {[x t.] ([.x t] :) [.x] ([.t] ty)})
  (def :.name : : -> [x t . x]
  = ([ascribed.]
    ([.ascribed] :.ty [value name ty.])
    [.name]
  ))
  (def :.type : : -> ([x t.] ([.t] ty))
  = ([ascribed.]
    ([.ascribed] :.ty [value name ty.])
    [.ty]
  ))
  (arr val.ty : val -> {[t.] ([.t] val) ([.t] ty)})
  (arr ty.intro : [t . t] -> ([t] ty))
  (arr ty.elim : ([t] ty) -> [t . t])
  (arr ty.copy : ([t] ty) -> {[t.] ([.t] ty) ([.t] ty)})
  (arr val.wrap : [a . a] -> ([a . a] val))

  # Distribute val over product objects.
  # A × B -> Val(A) × Val(B)
  (arr val.*.map :
    ([a b] *)
    ->
    {[a b.] ({([.a] val) ([.b] val)} *)}
  )
  # Val(A × B) -> Val(A) × Val(B)
  (arr val.*.elim : (* val) -> {val val})
  # Val(A) × Val(B) -> Val(A × B)
  (arr val.*.intro : {val val} -> (* val))

  # Modus ponens:
  #   h0 : |- φ
  #   h1 : |- φ → ψ
  # ----------------
  #   r0 : |- ψ
  (arr ax-mp : {[ph ps.] # two metavars
    ([.ph] |-)            # |- φ
    ([.ph ps] ==> |-)      # |- (φ → ψ)
  } -> ([ph ps . ps] |-)) # |- ψ
})
