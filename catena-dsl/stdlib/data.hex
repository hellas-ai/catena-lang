# basic datatypes
(theory type nat { 
  # type literals
  (arr type : 1 -> 1)

  # booleans
  (arr bool : 0 -> 1)
})

(theory program type {
  # Boolean type literal.
  (arr bool.type : [] -> (bool type))

  # Boolean operations
  (arr bool.t : [] -> bool)
  (arr bool.f : [] -> bool)

  (arr bool.not : bool -> bool)
  (arr bool.or  : {bool bool} -> bool)
  (arr bool.and : {bool bool} -> bool)

  # execute one of two *closures* depending on a boolean flag
  #
  #   if : 2 ● (A => B) ● (A => B) -> (A => B)
  (arr bool.if : {bool =>} -> =>)

  # Execute one of two *converted closures* depending on a flag
  # (A "converted closure" is an explicit environment plus a fn pointer)
  #
  #   ifc : X ● (X * A -> B) ● Y ● (Y * A -> B) ● Bool ● A -> B
  (arr bool.ifc : {[x y a b.]
    [.x]
    ([.x a] {* [.b]} ->)
    [.y]
    ([.y a] {* [.b]} ->)
    bool
    [.a]
  } -> [x y a b . b])


  # temp helpers until we add polymorphic versions
  # unitors and associators for bools only
  (arr bool.id : bool -> bool)
  (arr bool.copy : bool -> {bool bool})
  (def bool.li : bool -> {1 bool} = {unit.intro [a]})
})
