# f32 inner product.
#
# Both inputs are indexed by the same b dimension.
#   reduce 0.0 (+) (\j -> lhs(j) * rhs(j)) b

(def program matmul.f32.add-reduce :
  ({(f32 val) (f32 val)} *)
  ->
  (f32 val)
= ([pair.]
  ([.pair] *.elim [acc value.])
  {[.acc value]} f32.add
))

(def program matmul-f32-product-at :
  ([b.] {
    ({({([.b] ix val) (f32 val)} =>) ({([.b] ix val) (f32 val)} =>)} *)
    ([.b] ix val)
  })
  ->
  ([b.] (f32 val))
= ([env j.]
  ([.env] *.elim [lhs rhs.])
  ({([.j] defer) [.lhs]} compose run [lval.])
  ({([.j] defer) [.rhs]} compose run [rval.])
  ([.lval rval] f32.mul [product.])
  [.product]
))

(def program matmul-f32-ix-identity :
  ([b.] ([.b] ix val))
  ->
  ([b.] ([.b] ix val))
= [i])

(def program matmul-f32-ix-unit-left-intro :
  ([b.] ([.b] ix val))
  ->
  ([b.] ({1 ([.b] ix val)} *))
= ({unit.intro [i]} *.intro))

(def program matmul-f32-apply-env :
  ([b.] {
    [.b]
    ({({([.b] ix val) (f32 val)} =>) ({([.b] ix val) (f32 val)} =>)} *)
    ({({
      ({({([.b] ix val) (f32 val)} =>) ({([.b] ix val) (f32 val)} =>)} *)
      ([.b] ix val)
    } *) (f32 val)} =>)
  })
  ->
  ([b.] ({([.b] ix val) (f32 val)} =>))
= ([b-dim env f.]
  ([.b-dim] name.matmul-f32-ix-unit-left-intro lift [unit-left.])
  ({
    ([.env] defer)
    ([.b-dim] name.matmul-f32-ix-identity lift)
  } tensor [capture.])
  ({[.unit-left capture]} compose [input-with-capture.])
  ({[.input-with-capture] [.f]} compose)
))

(def program matmul-f32-product-producer :
  ([b.] {
    ({([.b] ix val) (f32 val)} =>)
    ({([.b] ix val) (f32 val)} =>)
    [.b]
  })
  ->
  ([b.] ({([.b] ix val) (f32 val)} =>))
= ([lhs rhs b-dim.]
  {
    [.b-dim]
    ({[.lhs] [.rhs]} *.intro)
    ([.b-dim] name.matmul-f32-product-at lift)
  }
  matmul-f32-apply-env
))

(def program matmul-f32-inner :
  ([b.] {
    ({[.b] u64} :)
    ({([.b] ix val) (f32 val)} =>)
    ({([.b] ix val) (f32 val)} =>)
  })
  ->
  ([b.] (f32 val))
= ([b-len lhs rhs.]
  {
    [.lhs]
    [.rhs]
    ([.b-len] :.ty)
  }
  [lhs rhs b-len-for-reduce b-dim b-u64-ty.]
    ({[.lhs] [.rhs] [.b-dim]} matmul-f32-product-producer [product-at.]
    {
      (const.u32.0x00000000 u32.bitcast-f32)
      (name.matmul.f32.add-reduce lift)
      [.product-at]
      [.b-len-for-reduce] # b:u64
    }
    reduce)
))
