# Catena-lang analogue of examples/puzzles/pooling.hex.
#
# This file declares the extra index/product/buffer primitives it needs locally,
# instead of extending catena-lang/stdlib/*.hex.
#
# It models the per-index pooling behavior:
#
#   output[0] = input[0]
#   output[1] = input[1] + input[0]
#   output[i] = input[i] + input[i - 1] + input[i - 2], for i >= 2
#
# Unlike the core example, this does not use gpu.global or gpu views. It uses a
# simple input/output buffers plus an index. The nested branch program computes
# the pooled value at that index; the store wrapper writes it to the output.
#
# NOTE: this is a language-level example. The current catena-lang HIP renderer
# does not yet lower these locally declared f32/index primitives.

(theory type nat {
  (arr != : 2 -> 1)
})

(theory program type {
  # Local numeric/index primitives for this example.
  # Branch-producing predicates: the boolean controls `bool.ifc`, while the
  # propositions are threaded as branch environments.
  (arr u64.eq : {[x y b.]
    ({[.x] u64} :)
    ({[.y] u64} :)
  } -> {[x y b.]
    (bool val)
    ([.x y] = |-)  # selected branch: x = y
    ([.x y] != |-) # non-selected branch: x != y
  })
  (arr u64.nonzero.gt-zero : {[x.]
    ([.x 0] != |-)
  } -> {[x.]
    ({[.x] 0} > |-)
  })
  (def u64.is-zero : {[x.]
    ({[.x] u64} :)
  } -> {[x.]
    (bool val)
    ({[.x] 0} = |-) # selected branch: x = 0
    ({[.x] 0} > |-) # non-selected branch: x > 0
  }
  =
  {[x.]
    ([] u64.zero [zero.])
    ([.x zero] u64.eq [is_zero zero_case nonzero_case.])
    ([.nonzero_case] u64.nonzero.gt-zero [gt_zero.])
    [.is_zero zero_case gt_zero]
  })
  (arr u64.as-type : {[x.] (u64 val)} -> ({[x] u64} :))
  (arr u64.one.judgement : [] -> ({1 u64} :))
  (arr :.unpack : {[x t.]
    ({[.x] [.t]} :)
  } -> {[x t.]
    [.x]
    [.t]
    ({[.x] [.t]} :)
  })
  (arr u64.one.gt-zero : {[x.]
    ([.x 1] = |-) 
  } -> {[x.]
    ([.x 0] > |-) 
  })
  (arr u64.neq-zero-neq-one.gt-one : {[x.]
    ([.x 0] != |-) 
    ([.x 1] != |-) 
  } -> {[x.]
    ([.x 1] > |-) 
  })
  (arr u64.pred : {[x y pred.]
    ({[.x] u64} :)
    ([.x y] > |-)
  } -> {[x y pred.]
    ({[.pred] u64} :)
  })
  (arr u64.pred.gt-zero : {[x pred.]
    ([.x 1] > |-)
    ({[.pred] u64} :)
  } -> {[x pred.]
    ([.pred 0] > |-)
  })
  (arr u64.pred2 : {[x pred2.]
    ({[.x] u64} :)
    ([.x 1] > |-)
  } -> {[x pred2.]
    ({[.pred2] u64} :)
  })

  # Extract the numeric value of a valid index together with its range proof.
  (arr ix.index : {[n position.]
    ([.n] ix val)
  } -> {[n position.]
    ({[.position] u64} :)
    ([.n position] > |-) 
  })
  (arr ix.extent : {[n.]
    ([.n] ix val)
  } -> {[n.]
    [.n]
  })
  (arr u64.pred.lt-n : {[n x y pred.]
    ([.n x] > |-) 
    ([.x y] > |-)
    ({[.pred] u64} :)
  } -> {[n x y pred.]
    ([.n pred] > |-) 
  })
  (arr u64.pred2.lt-n : {[n x pred2.]
    ([.n x] > |-) 
    ([.x 1] > |-)
    ({[.pred2] u64} :)
  } -> {[n x pred2.]
    ([.n pred2] > |-) 
  })
  (arr u64.pred.in-range : {[n x pred.]
    ({[.x] u64} :)
    ([.n x] > |-) 
    ([.x 0] > |-)
  } -> {[n x pred.]
    ({[.pred] u64} :)
    ([.n pred] > |-) 
  })
  (arr u64.pred2.in-range : {[n x pred pred2.]
    ({[.x] u64} :)
    ([.n x] > |-) 
    ([.x 1] > |-)
  } -> {[n x pred pred2.]
    ({[.pred] u64} :)
    ([.n pred] > |-) 
    ({[.pred2] u64} :)
    ([.n pred2] > |-) 
  })
  (arr ix.from-u64 : {[n position.]
    ({[.position] u64} :)
    ([.n position] > |-) 
  } -> {[n position.]
    ([.n] ix val)
  })
  (arr product.intro : {[a b.]
    ([.a])
    ([.b])
  } -> {[a b.]
    ({[.a] [.b]} *)
  })
  (arr product.elim : {[a b.]
    ({[.a] [.b]} *)
  } -> {[a b.]
    ([.a])
    ([.b])
  })
  (def pool.payload.intro :
    {[n position.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
      ({[.position] u64} :)
      ([.n position] > |-) 
    }
    ->
    {[n position.]
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.position] u64} :)
            ([.n position] > |-) 
          } *)
        } *)
      } *)
    }
    =
    {[input index position position_lt_n.]
      ([.position position_lt_n] product.intro [position_range.])
      ([.index position_range] product.intro [index_position_range.])
      ([.input index_position_range] product.intro [payload.])
      [.payload]
    })
  (def pool.payload.elim :
    {[n position.]
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.position] u64} :)
            ([.n position] > |-) 
          } *)
        } *)
      } *)
    }
    ->
    {[n position.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
      ({[.position] u64} :)
      ([.n position] > |-) 
    }
    =
    {[payload.]
      ([.payload] product.elim [input index_position_range.])
      ([.index_position_range] product.elim [index position_range.])
      ([.position_range] product.elim [position position_lt_n.])
      [.input index position position_lt_n]
    })
  (arr f32.buf.store :
    {[n.]
      ({cap.own [.n] f32} buf val)
      ([.n] ix val)
      (f32 val)
    }
    ->
    {[n.]
      ({cap.own [.n] f32} buf val)
    })
  (arr f32.buf.load2 :
    {[n.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
      ([.n] ix val)
    }
    ->
    {[n.]
      (f32 val)
      (f32 val)
    })
  (arr f32.buf.load-zero :
    {[n position.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
      ({[.position] 0} = |-)
    }
    ->
    {[n position.]
      (f32 val)
    })
  (arr f32.buf.load3 :
    {[n.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
      ([.n] ix val)
      ([.n] ix val)
    }
    ->
    {[n.]
      (f32 val)
      (f32 val)
      (f32 val)
    })
  (arr f32.buf.pool-many :
    {[n position.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
      ({[.position] u64} :)
      ([.n position] > |-) 
      ([.position 1] > |-)
    }
    ->
    {[n position.]
      (f32 val)
    })
  (def f32.pool-at-zero :
    {[n position.]
      ({[.position] 0} = |-)
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.position] u64} :)
            ([.n position] > |-) 
          } *)
        } *)
      } *)
    }
    -> {[n position.] (f32 val)}
    =
    {[env payload.]
      ([.payload] pool.payload.elim [input index position position_lt_n.])
      ([.input index env] f32.buf.load-zero [current.])
      [.current]
    })

  (arr f32.pool-at-one :
    {[n position.]
      ({[.position] 1} = |-)
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.position] u64} :)
            ([.n position] > |-) 
          } *)
        } *)
      } *)
    }
    -> {[n position.] (f32 val)}
  )

  (arr f32.pool-at-many :
    {[n position y.]
      ([.position y] != |-)
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.position] u64} :)
            ([.n position] > |-) 
          } *)
        } *)
      } *)
    }
    -> {[n position y.] (f32 val)}
  )

})

(def program f32.pool-nonzero :
  {[n position.]
    ({[.position] 0} > |-)
    ({
      ({cap.ref [.n] f32} buf val)
      ({
        ([.n] ix val)
        ({
          ({[.position] u64} :)
          ([.n position] > |-) 
        } *)
      } *)
    } *)
  }
  ->
  {[n position.] (f32 val)}
  =
  {[env payload.]
    ([.payload] pool.payload.elim [input index u64_position position_lt_n.])
    ([.index] ix.extent [extent.])
    ([] u64.one.judgement :.unpack [one one_type u64_one.])
    ([.u64_position u64_one] u64.eq [is_one one_case many_case.])
    ([.u64_position] :.unpack [position_param position_type unused_position_judgement.])
    ([.input index u64_position position_lt_n] pool.payload.intro [payload_inner.])

    # Inner if:
    #   if index == 1:
    #     input[index] + input[index - 1]
    #   else:
    #     input[index] + input[index - 1] + input[index - 2]
    ({
      ([.one_case])
      ([.extent position_param] name.f32.pool-at-one)
      ([.many_case])
      ([.extent position_param one] name.f32.pool-at-many)
      ([.is_one])
      ([.payload_inner])
    } bool.ifc [pooled.])
    [.pooled]
  }
)

(def program f32.pooling-last-three :
  {[n.]
    ({cap.ref [.n] f32} buf val)
    ({cap.own [.n] f32} buf val)
    ([.n] ix val)
  }
  ->
  {[n.]
    ({cap.own [.n] f32} buf val)
  }
  =
  {[input output index.]
    ([.index] ix.extent [extent.])
    ([.index] ix.index [u64_position position_lt_n.])
    ([.u64_position] u64.is-zero [is_zero zero_case nonzero_case.])
    ([.u64_position] :.unpack [position_param position_type _u64_position.])
    ([.input index u64_position position_lt_n] pool.payload.intro [payload.])

    # Outer if:
    #   if index == 0:
    #     input[index]
    #   else:
    #     run the nested non-zero decision above
    ({
      ([.zero_case])
      ([.extent position_param] name.f32.pool-at-zero)
      ([.nonzero_case])
      ([.extent position_param] name.f32.pool-nonzero)
      ([.is_zero])
      ([.payload])
    } bool.ifc [pooled.])

    ([.output index pooled] f32.buf.store [output_pooled.])

    [.output_pooled]
  }
)
