(theory syntax nat {
  (arr f32 : 0 -> 1)
  (arr bool : 0 -> 1)
  (arr nat : 0 -> 1)
  (arr product : 2 -> 1)
  (arr unit : 0 -> 1)
  (arr coproduct : 2 -> 1)
  (arr counit : 0 -> 1)
})

(theory data syntax {
  (arr f32.zero : [] -> f32)
  (arr f32.one : [] -> f32)
  (arr nat.bound : [] -> nat)
  (arr f32.add : {f32 f32} -> f32)
  (arr bool.gt : {f32 f32} -> bool)
  (arr bool.or : {bool bool} -> bool)

  (arr copy : [x] -> [x . x x])
  (arr discard : [x] -> [x.])

  (def projl : [x y] -> [x y . x] = {[x] discard})
  (def projr : [x y] -> [x y . y] = {discard [y]})

  (def any-positive : {f32 f32} -> bool =
    ({
      ({[x] f32.zero} bool.gt)
      ({[y] f32.zero} bool.gt)
    } bool.or))

  (def any-positive.bind : {f32 f32 [x]} -> {bool [x]} =
    {[a b x.]
      ([.a b] any-positive [condition.])
      ([.condition x])
    })

  (arr any-positive.bounded.bind : {nat ({f32 f32} product) [x]} -> {bool [x]})

  (def add-one-first : {f32 f32} -> {f32 f32} =
    {
      ({[x] f32.one} f32.add)
      [y]
    })

  (def add-one-second : {f32 f32} -> {f32 f32} =
    {
      [x]
      ({[y] f32.one} f32.add)
    })

  (arr add-one-first.bounded :
    {nat ({f32 f32} product)} -> {nat ({f32 f32} product)})

  (arr drop-bound-f32-pair : {nat ({f32 f32} product)} -> {f32 f32})
})

(theory control syntax {
  (arr merge : [x . x x] -> [x])
  (arr create : [x.] -> [x])
  (arr branch : [x] -> [x . x x])
  (arr discard : [x] -> [x.])
  (arr guard : ({bool [x]} product) -> [x . x x])
  (arr for-n.step :
    ([x . x x] {
      [x] # entry
      ({nat [x]} product) # continue loop
    }) ->
    ([x . x x] {
      ({nat [x]} product) # loop body
      [x] # exit
    }))

  (def guarded-positive-update :
    ({f32 f32} product) ->
    {({f32 f32} product) ({f32 f32} product)}
    =
    (
      data.copy
      data.any-positive.bind
      guard
      {data.add-one-second data.add-one-first}
    ))

  (def while-positive-update :
    ({f32 f32} product) -> ({f32 f32} product)
    =
    {[entry.]
      ([.entry] data.copy data.any-positive.bind guard [iter done.])
        ([.iter] data.add-one-first [entry.])
      ([.done])
    })

  (def for-n-positive-update :
    ({f32 f32} product) -> ({f32 f32} product)
    =
    {[start.]
      ([.start loopback] for-n.step [bounded exhausted.])
        ([.bounded] data.copy data.any-positive.bounded.bind guard [iter condition_done.])
          ([.iter] data.add-one-first.bounded [loopback.])

      ([.condition_done] data.drop-bound-f32-pair [condition_done_unbounded.])
      ([.exhausted condition_done_unbounded] merge [done.])
      ([.done])
    })
})
