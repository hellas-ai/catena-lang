(theory type nat {
  # products
  (arr * : 2 -> 1)
  (arr 1 : 0 -> 1)
})

(theory program type {
  (arr unit.intro : [] -> 1)
  (arr unit.elim : [] -> 1)
  (arr *.intro : [a b] -> *)
  (arr *.elim : * -> [a b])

  # Left unit introduction: A -> 1 * A.
  (def product.left-intro : [a] -> {1 [a]} = {unit.intro [x]})
})
