(theory type nat {
  (arr * : 2 -> 1)
  (arr -> : 2 -> 1)
  (arr 0 : 0 -> 1)
  (arr 1 : 0 -> 1)
  (arr : : 2 -> 1)
  (arr = : 2 -> 1)
  (arr ==> : 2 -> 1)
  (arr => : 2 -> 1)
  (arr > : 2 -> 1)
  (arr bool : 0 -> 1)
  (arr bool.f : 0 -> 1)
  (arr bool.t : 0 -> 1)
  (arr buf : 3 -> 1)
  (arr cap.own : 0 -> 1)
  (arr cap.ref : 0 -> 1)
  (arr eval : 2 -> 1)
  (arr f32 : 0 -> 1)
  (arr gpu.3d : 0 -> 1)
  (arr gpu.buf : 1 -> 1)
  (arr gpu.env : 0 -> 1)
  (arr gpu.launch_params : 0 -> 1)
  (arr gpu.state : 0 -> 1)
  (arr ix : 1 -> 1)
  (arr mem : 1 -> 1)
  (arr not : 1 -> 1)
  (arr u64 : 0 -> 1)
  (arr val : 1 -> 1)
  (arr |- : 1 -> 1)
})