# Minimal bool.ifc case where only the payload is dependent.
#
# The branch environments are ordinary booleans, like plain_ifc.hex. The branch
# payload is Ix n, so the branch function names still have to carry the
# dependent parameter n.

(theory program type {
  (arr ix.extent :
    {[n.]
      ([.n] ix val)
    }
    ->
    {[n.]
      [.n]
      ([.n] ix val)
    })

  (arr dep.payload.then :
    {[n.]
      (bool val)
      ([.n] ix val)
    }
    ->
    {[n.]
      (bool val)
    })

  (arr dep.payload.else :
    {[n.]
      (bool val)
      ([.n] ix val)
    }
    ->
    {[n.]
      (bool val)
    })
})

(def program dep.payload.ifc :
  {[n.]
    (bool val)
    ([.n] ix val)
  }
  ->
  {[n.]
    (bool val)
  }
  =
  {[flag index.]
    ([] bool.t [then_env.])
    ([] bool.f [else_env.])
    ([.index] ix.extent [extent index_payload.])
    ([.extent] name.dep.payload.then [then_fn.])
    ([.extent] name.dep.payload.else [else_fn.])
    ({
      ([.then_env])
      ([.then_fn])
      ([.else_env])
      ([.else_fn])
      ([.flag])
      ([.index_payload])
    } bool.ifc [out.])
    [.out]
  })
