# f32 inner product.
#
# Both inputs are indexed by the same b dimension.
#   reduce 0.0 (+) (\j -> lhs(j) * rhs(j)) b

(def program matmul.f32.add-reduce :
  ({(f32 val) (f32 val)} *)
  ->
  (f32 val)
= ([pair.]
  ([.pair] *.elim [acc value.])
  {[.acc value]} f32.add
))

(def program matmul-f32-product-at :
  ([b.] {
    ({({([.b] ix val) (f32 val)} =>) ({([.b] ix val) (f32 val)} =>)} *)
    ([.b] ix val)
  })
  ->
  ([b.] (f32 val))
= ([env j.]
  ([.env] *.elim [lhs rhs.])
  ({([.j] defer) [.lhs]} compose run [lval.])
  ({([.j] defer) [.rhs]} compose run [rval.])
  ([.lval rval] f32.mul [product.])
  [.product]
))

(def program matmul-f32-ix-identity :
  ([b.] ([.b] ix val))
  ->
  ([b.] ([.b] ix val))
= [i])

(def program matmul-f32-ix-unit-left-intro :
  ([b.] ([.b] ix val))
  ->
  ([b.] ({1 ([.b] ix val)} *))
= ({unit.intro [i]} *.intro))

(def program matmul-f32-product-dims :
  ([b.] ({[.b] u64} :))
  ->
  ([b.] {
    ({[.b] u64} :)
    [.b]
    [.b]
    [.b]
  })
= ([b-len.]
  ([.b-len] :.ty [b-len-for-unit b-for-product b-u64-ty-product.]
    ([.b-len-for-unit] :.ty [b-len-for-identity b-for-unit b-u64-ty-unit.]
      ([.b-len-for-identity] :.ty [b-len-for-reduce b-for-identity b-u64-ty-identity.]
        {
          [.b-len-for-reduce]
          [.b-for-product]
          [.b-for-unit]
          [.b-for-identity]
        }
      )
    )
  )
))

(def program matmul-f32-dot-product-producer :
  ([b.] {
    [.b]
    [.b]
    [.b]
    ({({([.b] ix val) (f32 val)} =>) ({([.b] ix val) (f32 val)} =>)} *)
  })
  ->
  ([b.] ({([.b] ix val) (f32 val)} =>))
= ([b-for-unit b-for-identity b-for-product operands.]
  ([.b-for-unit] name.matmul-f32-ix-unit-left-intro lift [unit-left.])
  ({
    ([.operands] defer)
    ([.b-for-identity] name.matmul-f32-ix-identity lift)
  } tensor [capture.])
  ({[.unit-left capture]} compose [input-with-capture.])
  ({[.input-with-capture] ([.b-for-product] name.matmul-f32-product-at lift)} compose)
))

(def program matmul-f32-inner :
  ([b.] {
    ({[.b] u64} :)
    ({([.b] ix val) (f32 val)} =>)
    ({([.b] ix val) (f32 val)} =>)
  })
  ->
  ([b.] (f32 val))
= ([b-len lhs rhs.]
  ([.b-len] matmul-f32-product-dims [b-len-for-reduce b-for-product b-for-unit b-for-identity.]
    ({
      [.b-for-unit]
      [.b-for-identity]
      [.b-for-product]
      ({[.lhs] [.rhs]} *.intro)
    }
    matmul-f32-dot-product-producer [product-at.]
    {
      (const.u32.0x00000000 u32.bitcast-f32)
      (name.matmul.f32.add-reduce lift)
      [.product-at]
      [.b-len-for-reduce] # b:u64
    }
    reduce)
  ))
)
