#
# Sum-pooling over a 1D array using shared memory.
# window_radius is provided through the launcher/CLI and gives a window of
# [global_index - window_radius, global_index + window_radius].
#

(def data user.f32.pool1d-sum :
    {
      (([.element_count] extent) val)
      (([.thread_count] extent) val)
      (([.window_radius] extent) val)
      (({(({[element_count] [thread_count]} nat.ceil-div) 1d) ([thread_count] 1d)} gpu.grid) val)
      (({f32 ([thread_count] 1d)} gpu.shared) val)
      (({f32 ([element_count] 1d)} gpu.global) val)
      (({f32 ([element_count] 1d)} gpu.global) val)
    } ->
    {
      [element_count thread_count window_radius.]
      (({f32 ([thread_count] 1d)} gpu.shared) val)
      (({f32 ([element_count] 1d)} gpu.global) val)
      (({f32 ([element_count] 1d)} gpu.global) val)
    }
    = {[element_count thread_count window_radius grid scratch input output.]
      ([.grid] gpu.grid.schedule [block thread.])
      ([.block thread thread_count] gpu.view.group [global_view.])
      ([.thread] gpu.view.element [local_view.])
      ([.input global_view] gpu.global.load [input_value.])
      ([.scratch local_view input_value] gpu.shared.store [scratch_loaded.])
      ([.scratch_loaded] gpu.sync [scratch_synced.])
      ([.] f32.zero [zero.])
      ([.] f32.type bound.eta [acc_r acc.])
      ([.window_radius] extent.index-type bound.eta [offset_r offset.])
      ([.global_view offset] gpu.view.sub [neighbor_index.])
      ([.local_view offset] gpu.view.sub [local_neighbor_index.])
      ([.global_view offset] gpu.view.ge [global_has_left_neighbor.])
      ([.local_view offset] gpu.view.ge [local_has_left_neighbor.])
      ([.neighbor_index] gpu.index.nonnegative [neighbor_nonnegative.])
      ([.neighbor_index element_count] gpu.index.lt-extent [neighbor_in_range.])
      ([.neighbor_nonnegative neighbor_in_range] bool.and [valid_neighbor.])
      ([.valid_neighbor local_has_left_neighbor] bool.and [use_shared_neighbor.])
      ([.input neighbor_index element_count zero]
        gpu.global.load-or
        [global_neighbor_value.])
      ([.use_shared_neighbor scratch_synced local_neighbor_index zero]
        gpu.shared.load-if
        [shared_neighbor_value.])
      ([.use_shared_neighbor shared_neighbor_value global_neighbor_value]
        f32.select
        [neighbor_value.])
      ([.acc neighbor_value] f32.add [acc_next.])
      ([.window_radius zero acc_r offset_r acc_next]
        reduce
        [pooled.])
      ([.output global_view pooled] gpu.global.store [output_pooled.])
      [.scratch_synced input output_pooled]}
)
