(theory syntax nat {
  (arr nat : 0 -> 1)
  (arr extent : 1 -> 1)
  (arr index : 1 -> 1)
  (arr bool : 0 -> 1)
  (arr f32 : 0 -> 1)
  (arr gpu.block : 0 -> 1)
  (arr gpu.thread : 0 -> 1)
  (arr gpu.tiled-matmul.state : 0 -> 1)
  (arr gpu.tiled-matmul.done : 0 -> 1)
  (arr gpu.tiled-matmul.p-iteration : 0 -> 1)
  (arr gpu.tiled-matmul.q-iteration : 0 -> 1)
  # gpu.global(f32, rows, cols) => global float matrix [rows][cols]
  (arr gpu.global : 3 -> 1)
  # gpu.view(tile_size) => one thread-owned element view into a tiled matrix
  (arr gpu.view : 1 -> 1)
  # gpu.shared(f32, tile_size, tile_size) => float [tile_size][tile_size]
  # we could use literals instead of nats
  (arr gpu.shared : 3 -> 1)

  (arr value : 1 -> 1)
  (arr bound : 1 -> 1)
  # a wire labeled with unique cannot be split or discarded 
  (arr unique : 1 -> 1)
  # a wire labeled with const cannot be output of a box
  (arr const : 1 -> 1)

  (arr product : 2 -> 1)
  (arr coproduct : 2 -> 1)
  (arr unit : 0 -> 1)
  (arr counit : 0 -> 1)
})

(theory data syntax {
  (arr gpu.block : [] -> gpu.block)
  (arr gpu.thread : [] -> gpu.thread)

  (arr global : [n] -> ([n . n n] {f32 [n] [n]} gpu.global))
  (arr shared : [n] -> ([n . n n] {f32 [n] [n]} gpu.shared))
  (arr f32 : [] -> f32)
  (arr value.type : value -> [t])
  (arr extent.raw : extent -> [n])
  (arr extent.index-type : extent -> index)
  (arr extent.const-value :
    (([x] extent) const) ->
    (([x] extent) value))
  (arr extent.const-index-type :
    (([x] extent) const) ->
    ([x] index))
  (arr bound.eta : [t] -> ([t . t t] {bound value}))

  (arr reduce :
    {
      (extent value)
      ([x] value)
      ([x] bound)
      (([tile_size] index) bound)
      ([x] value)
    } ->
    ([tile_size x x tile_size x . x] value))

  (arr sync :
    ([x] unique) ->
    ([x] unique))

  (arr sync-2 :
    {([x] unique) ([y] unique)} ->
    {([x] unique) ([y] unique)})

  (arr sync-3 :
    {([x] unique) ([y] unique) ([z] unique)} ->
    {([x] unique) ([y] unique) ([z] unique)})

  (arr thread.x :
    {(([tile_size] extent) const) (gpu.thread const)} ->
    (([tile_size] index) value))

  (arr thread.y :
    {(([tile_size] extent) const) (gpu.thread const)} ->
    (([tile_size] index) value))

  (arr gpu.shared.load :
    {[tile ix iy]} ->
    ([tile ix iy.] f32 value))

  (arr block.row :
    {(([m] extent) const) (([tile_size] extent) const) (gpu.block const) (gpu.thread const)} ->
    (([m tile_size . m] index) value))

  (arr block.col :
    {(([n] extent) const) (([tile_size] extent) const) (gpu.block const) (gpu.thread const)} ->
    (([n tile_size . n] index) value))

  (arr current-tile.offset :
    {[target_extent tile_extent current_tile local]} ->
    ([target_extent tile_extent current_tile local . target_extent] index value))

  (arr gpu.global.load :
    {[matrix] (([tile_size] gpu.view) value)} ->
    ([matrix tile_size.] f32 value))

  # Views follow the trick used in Descent-style safe parallel access: a resource
  # may be unique at block scope, but a view proves which thread owns a specific
  # piece of that resource. Without the view, the whole block owns the tile or
  # matrix. With the view, load/store can expose per-thread ownership while the
  # unique resource still tracks exclusive access at the block level.
  (arr gpu.view.thread :
    {(([tile_size] extent) const) (gpu.thread const)} ->
    (([tile_size] gpu.view) value))

  (arr gpu.view.block_row_current_tile_col :
    {(([tile_size] index) value) (gpu.block const) (gpu.thread const)} ->
    (([tile_size] gpu.view) value))

  (arr gpu.view.current_tile_row_block_col :
    {(([tile_size] index) value) (gpu.block const) (gpu.thread const)} ->
    (([tile_size] gpu.view) value))

  (arr gpu.view.group_by_tile :
    {(([tile_size] extent) const) (gpu.block const) (gpu.thread const)} ->
    (([tile_size] gpu.view) value))

  (arr gpu.global.store :
    {([matrix] unique) (([tile_size] gpu.view) value) (f32 value)} ->
    ([matrix tile_size . matrix] unique))

  (arr gpu.shared.store :
    {([tile] unique) (([tile_size] gpu.view) value) (f32 value)} ->
    ([tile tile_size . tile] unique))

  (arr ceil-div : {(extent const) (extent const)} -> ([tile k . tile] extent value))
  (arr f32.zero : [] -> (f32 value))
  (arr f32.mul : {(f32 value) (f32 value)} -> (f32 value))
  (arr f32.add : {(f32 value) (f32 value)} -> (f32 value))

  (def cooperative-global-to-shared :
    {
      (([.tile_size] extent) const)
      (([.m] extent) const)
      (([.k] extent) const)
      (([.n] extent) const)
      (gpu.block const)
      (gpu.thread const)
      (([tile_size] index) value)
      (({f32 [m] [k]} gpu.global) value)
      (({f32 [k] [n]} gpu.global) value)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
    } ->
    {
      (([tile_size] index) value)
      (({f32 [m] [k]} gpu.global) value)
      (({f32 [k] [n]} gpu.global) value)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
    }
    =
    {[tile_size m k n block thread current_tile global_a global_b tile_a tile_b.]
      ([.tile_size thread] gpu.view.thread [shared_thread_view.])

      # tile_A[thread.y, thread.x] = A[row, current_tile * TILE + thread.x]
      # A.group_by_tile::<tile_size, tile_size>
      #  .select_tile_row_from_block_y_and_tile_col::<current_tile>
      #  [[block]][[thread]]
      ([.current_tile block thread] gpu.view.block_row_current_tile_col [a_view.])
      ([.global_a a_view] gpu.global.load [a_val.])
      ([.tile_a shared_thread_view a_val] gpu.shared.store
        [tile_a_loaded.])

      # tile_B[thread.y, thread.x] = B[current_tile * TILE + thread.y, col]
      # B.group_by_tile::<tile_size, tile_size>
      #  .select_tile_row::<current_tile>_and_tile_col_from_block_x
      #  [[block]][[thread]]
      ([.current_tile block thread] gpu.view.current_tile_row_block_col [b_view.])
      ([.global_b b_view] gpu.global.load [b_val.])
      ([.tile_b shared_thread_view b_val] gpu.shared.store
        [tile_b_loaded.])

      ([.current_tile global_a global_b tile_a_loaded tile_b_loaded])
    })

  (def tile.dot-product :
    {
      (([.tile_size] extent) const)
      (gpu.thread const)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (f32 value)
    } ->
    {
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (f32 value)
    }
    =
    {[tile_size thread tile_a tile_b acc.]
      # for tile_inner_index in range(tile_size):
      #   acc += tile_A[thread.y, tile_inner_index] * tile_B[tile_inner_index, thread.x]

      # Loop setup.
      ([.tile_size] extent.const-index-type bound.eta
        [tile_inner_index_r tile_inner_index.])
      ([.tile_size] extent.const-value [tile_size_value.])
      ([.] f32 bound.eta
        [acc_r acc_q.])

      # Loop body.
      ([.tile_size thread] thread.y [thread_y.])
      ([.tile_size thread] thread.x [thread_x.])
      ([.tile_a thread_y tile_inner_index] gpu.shared.load
        [a_val.])
      ([.tile_b tile_inner_index thread_x] gpu.shared.load
        [b_val.])
      ([.a_val b_val] f32.mul [dot.])
      ([.acc_q dot] f32.add [acc_next.])

      # Close the bounded loop.
      ([.tile_size_value acc acc_r tile_inner_index_r acc_next]
        reduce
        [acc_out.])

      ([.tile_a tile_b acc_out])
    })

  (def gpu.tiled_matmul.dataflow :
    {
      (([.tile_size] extent) const)
      (([.m] extent) const)
      (([.k] extent) const)
      (([.n] extent) const)
      (gpu.block const)
      (gpu.thread const)
      (({f32 [m] [k]} gpu.global) value) # A
      (({f32 [k] [n]} gpu.global) value) # B
      (({f32 [m] [n]} gpu.global) unique) # C
      (({f32 [tile_size] [tile_size]} gpu.shared) unique) # tile_A
      (({f32 [tile_size] [tile_size]} gpu.shared) unique) # tile_B
    } ->
    {
      (([.tile_size] extent) const)
      (([.m] extent) const)
      (([.k] extent) const)
      (([.n] extent) const)
      (gpu.block const)
      (gpu.thread const)
      (({f32 [m] [k]} gpu.global) value)
      (({f32 [k] [n]} gpu.global) value)
      (({f32 [m] [n]} gpu.global) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
    }
    =
    {[tile_size m k n block thread global_a global_b global_c tile_a tile_b.]
      # row = block.y * TILE + thread.y
      # col = block.x * TILE + thread.x
      # for current_tile in range(ceil_div(k, tile_size)):
      #   load global A/B tile slices into shared memory
      #   acc = dot(tile_A[thread.y, :], tile_B[:, thread.x])
      # C[row, col] = acc

      # Loop setup.
      ([.tile_size k] ceil-div [num_tiles.])
      ([.] f32.zero [acc0.])
      ([.num_tiles] value.type [num_tiles_extent.])
      ([.num_tiles_extent] extent.index-type bound.eta
        [current_tile_r current_tile.])
      ([.] f32 bound.eta
        [acc_r acc_p.])

      # Loop body.
      ([.tile_size m k n block thread current_tile global_a global_b tile_a tile_b]
        cooperative-global-to-shared
        [current_tile_loaded global_a_loaded global_b_loaded tile_a_loaded tile_b_loaded.])

      # sync: all threads in the block have written tile_A and tile_B before any
      # thread reads from shared memory for the dot product.
      ([.tile_a_loaded tile_b_loaded]
        sync-2
        [tile_a_visible tile_b_visible.])
      ([.tile_size thread tile_a_visible tile_b_visible acc_p]
        tile.dot-product
        [tile_a_q tile_b_q acc_next.])

      # sync: all threads have finished reading the current shared tiles before
      # the next current_tile iteration overwrites tile_A and tile_B.
      ([.tile_a_q tile_b_q]
        sync-2
        [tile_a_reusable tile_b_reusable.])

      # Close the bounded loop.
      ([.num_tiles acc0 acc_r current_tile_r acc_next]
        reduce
        [acc_done.])

      # C.group_by_tile::<tile_size, tile_size>[[block]][[thread]] = acc
      ([.tile_size block thread] gpu.view.group_by_tile [c_view.])
      ([.global_c c_view acc_done] gpu.global.store [global_c_out.])
      ([.tile_size m k n block thread global_a_loaded global_b_loaded global_c_out tile_a_reusable tile_b_reusable])
    })
})

(theory control syntax {
  (arr sync : [x] -> [x])

  (arr gpu.tiled-matmul.state : [] -> gpu.tiled-matmul.state)
  (arr gpu.tiled-matmul.p-iteration : [] -> gpu.tiled-matmul.p-iteration)
  (arr gpu.tiled-matmul.q-iteration : [] -> gpu.tiled-matmul.q-iteration)

  (arr gpu.tiled-matmul.for-num-tiles.prelude :
    {
      (gpu.tiled-matmul.state value)
      (gpu.tiled-matmul.state value)
    } ->
    {
      (gpu.tiled-matmul.p-iteration value)
      (gpu.tiled-matmul.state value)
    })

  (arr gpu.tiled-matmul.for-tile.prelude :
    {
      (gpu.tiled-matmul.state value)
      (gpu.tiled-matmul.state value)
    } ->
    {
      (gpu.tiled-matmul.q-iteration value)
      (gpu.tiled-matmul.state value)
    })

  (arr gpu.tiled-matmul.init-acc :
    (gpu.tiled-matmul.state value) ->
    (gpu.tiled-matmul.state value))

  (arr gpu.tiled-matmul.collectively-load-shared-tile :
    (gpu.tiled-matmul.p-iteration value) ->
    (gpu.tiled-matmul.state value))

  (arr gpu.tiled-matmul.dot-by-thread :
    (gpu.tiled-matmul.q-iteration value) ->
    (gpu.tiled-matmul.state value))

  (arr gpu.tiled-matmul.store-output :
    (gpu.tiled-matmul.state value) ->
    (gpu.tiled-matmul.done value))

  (arr gpu.tiled-matmul.barrier.sync :
    {
      (gpu.tiled-matmul.state value)
      (gpu.tiled-matmul.state value)
    } ->
    {
      (gpu.tiled-matmul.state value)
      (gpu.tiled-matmul.state value)
    })

  (arr gpu.tiled-matmul.barrier.compute :
    {
      (gpu.tiled-matmul.state value)
      (gpu.tiled-matmul.state value)
    } ->
    {
      (gpu.tiled-matmul.state value)
      (gpu.tiled-matmul.state value)
    })

  (def gpu.tiled_matmul.controlflow :
    {
      (gpu.tiled-matmul.state value)
      (gpu.tiled-matmul.state value)
      (gpu.tiled-matmul.state value)
    } ->
    {
      (gpu.tiled-matmul.done value)
      (gpu.tiled-matmul.state value)
      (gpu.tiled-matmul.state value)
    }
    =
    {[start after_sync_phase after_compute_phase.]
      ([.start] gpu.tiled-matmul.init-acc [x0.])

      # Outer p-loop: either run one tile body or return the final carried state.
      ([.x0 p_loopback]
        gpu.tiled-matmul.for-num-tiles.prelude
        [p_iter p_return.])

        # Load the current A/B tile fragments, then suspend at the load barrier.
        ([.p_iter]
          gpu.tiled-matmul.collectively-load-shared-tile
          [wait_other_threads.])
        ([.wait_other_threads after_sync_phase]
          gpu.tiled-matmul.barrier.sync
          [x_loaded wait_other_threads_out.])

        # Inner q-loop: repeatedly update the accumulator from shared tiles.
        ([.x_loaded q_loopback]
          gpu.tiled-matmul.for-tile.prelude
          [q_iter q_return.])
          ([.q_iter]
            gpu.tiled-matmul.dot-by-thread
            [q_loopback.])

        # Suspend before the next p-iteration can overwrite shared tiles.
        ([.q_return after_compute_phase]
          gpu.tiled-matmul.barrier.compute
          [p_loopback wait_after_compute_out.])

      ([.p_return] gpu.tiled-matmul.store-output [y.])
      ([.y wait_other_threads_out wait_after_compute_out])
    })
})
