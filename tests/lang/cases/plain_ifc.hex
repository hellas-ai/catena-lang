# Minimal bool.ifc example with non-parameterized branch functions.
#
# This mirrors dependent_ifc.hex, but plain.then/plain.else do not depend on an
# external parameter like n. It is the working baseline for the dependent case.

(theory program type {
  (arr plain.then :
    {(bool val)
      (bool val)}
    ->
    (bool val))

  (arr plain.else :
    {(bool val)
      (bool val)}
    ->
    (bool val))
})

(def program plain.ifc :
  {(bool val)
   (bool val)}
  ->
  (bool val)
  = ([flag arg.]
    {bool.t name.plain.then bool.f name.plain.else [.flag arg]}
    bool.ifc
  ))
