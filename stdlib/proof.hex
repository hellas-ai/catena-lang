(theory syntax nat {
  (arr bool : 1 -> 1)
  (arr u64 : 1 -> 1)
  (arr true : 0 -> 1)
  (arr false : 0 -> 1)
  (arr = : 2 -> 1)
  (arr => : 2 -> 1)
  (arr not : 1 -> 1)
  (arr |- : 1 -> 1)
  (arr Ix : 1 -> 1)
  (arr buf : 2 -> 1)

  (arr u64.gt : 2 -> 1)
  (arr u64.lt : 2 -> 1)
  (arr u64.mul : 2 -> 1)
  (arr u64.add : 2 -> 1)
})

(theory proof syntax {


  (arr assert :
    ([b p . b b p]
      {([b] bool)
       (({({[b] true} =) [p]} =>) |-)}
      ) ->
    ([b p . p] ([p] |-)))

  (arr u64.gt :
    ([x y b . x y]
      {([x] u64)
       ([y] u64)}
      ) ->
    ([x y b . b b x y b x y]
      {([b] bool)
       (({({[b] true} =) ({[x] [y]} u64.gt)} =>) |-)
       (({({[b] false} =) (({[x] [y]} u64.gt) not)} =>) |-)}
      ))

  (arr u64.lt :
    ([x y b . x y]
      {([x] u64)
       ([y] u64)}
      ) ->
    ([x y b . b b x y b x y]
      {([b] bool)
       (({({[b] true} =) ({[x] [y]} u64.lt)} =>) |-)
       (({({[b] false} =) (({[x] [y]} u64.lt) not)} =>) |-)}
      ))

  (arr u64.mul :
    ([x y . x y]
      {([x] u64)
       ([y] u64)}
      ) ->
    ([x y . x y] (({[x] [y]} u64.mul) u64)))

  (arr u64.add :
    ([x y . x y]
      {([x] u64)
       ([y] u64)}
      ) ->
    ([x y . x y] (({[x] [y]} u64.add) u64)))

  (arr u64.index :
    ([x n . x x n]
      {([x] u64)
       (({[x] [n]} u64.lt) |-)}
      ) ->
    ([x n . n] ([n] Ix)))

  (arr write :
    ([n . n n]
      {({[n] f32} buf)
       ([n] Ix)
       f32}
      ) ->
    ([n . n] ({[n] f32} buf)))

  (arr read :
    ([n . n n]
      {({[n] f32} buf)
       ([n] Ix)}
      ) ->
    ([n .] f32))

  (def user.f32.write-imj :
    ([i j m n . i j m n n]
      {([i] u64)
       ([j] u64)
       ([m] u64)
       ([n] u64)
       ({[n] f32} buf)
       f32}
      ) ->
    ([i j m n . n] ({[n] f32} buf))
    =
    {[i j m n buffer value.]
      ([.i m] u64.mul [im.])
      ([.im j] u64.add [index.])
      ([.index n] u64.lt [is-in-bounds in-bounds-if-true in-bounds-if-false.])
      ([.is-in-bounds in-bounds-if-true] assert [in-bounds.])
      ([.index in-bounds] u64.index [ix.])
      ([.buffer ix value] write [updated.])
      [.updated]}
  )
})
