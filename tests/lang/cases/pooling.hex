# Catena-lang analogue of examples/puzzles/pooling.hex.
#
# This file declares the extra index/product/buffer primitives it needs locally,
# instead of extending catena-lang/stdlib/*.hex.
#
# It models the per-index pooling behavior:
#
#   output[0] = input[0]
#   output[1] = input[1] + input[0]
#   output[i] = input[i] + input[i - 1] + input[i - 2], for i >= 2
#
# Unlike the core example, this does not use gpu.global or gpu views. It uses a
# simple input/output buffers plus an index. The nested branch program computes
# the pooled value at that index; the store wrapper writes it to the output.
#
# NOTE: this is a language-level example. The current catena-lang HIP renderer
# does not yet lower these locally declared f32/index primitives.

(theory type nat {
  (arr != : 2 -> 1)
  (arr succ : 1 -> 1) 
})

(theory program type {
  # Local numeric/index primitives for this example.
  # Branch-producing predicates: the boolean controls `bool.ifc`, while the
  # propositions are threaded as branch environments.
  (arr u64.eq : {[x y b.]
    ({[.x] u64} :)
    ({[.y] u64} :)
  } -> {[x y b.]
    (bool val)
    ([.x y] = |-)  # selected branch: x = y
    ([.x y] != |-) # non-selected branch: x != y
  })
  (arr u64.nonzero.gt-zero : {[x.]
    ([.x 0] != |-)
  } -> {[x.]
    ({[.x] 0} > |-)
  })
  (def u64.is-zero : {[x.]
    ({[.x] u64} :)
  } -> {[x.]
    (bool val)
    ({[.x] 0} = |-) # selected branch: x = 0
    ({[.x] 0} > |-) # non-selected branch: x > 0
  }
  =
  {[x.]
    ([] u64.zero [zero.])
    ([.x zero] u64.eq [is_zero zero_case nonzero_case.])
    ([.nonzero_case] u64.nonzero.gt-zero [gt_zero.])
    [.is_zero zero_case gt_zero]
  })
  (arr :.unpack : {[x t.]
    ({[.x] [.t]} :)
  } -> {[x t.]
    [.x]
    [.t]
    ({[.x] [.t]} :)
  })
  (arr u64.is-succ : {[x y.]
    ({[.x] u64} :)
    ({[.y] u64} :)
    ({[.y] [.x]} > |-) # x < y
  } -> {[x y.]
    (bool val)
    ({([.x] succ) [.y]} = |-) # selected branch: x + 1 = y
    ({[.y] ([.x] succ)} > |-) # non-selected branch: x + 1 < y
  })
  (arr u64.succ-eq.gt-base : {[x y.]
    ({([.x] succ) [.y]} = |-)
  } -> {[x y.]
    ({[.y] [.x]} > |-)
  })
  (arr u64.gt.trans : {[x y z.]
    ({[.y] [.x]} > |-)
    ([.z y] > |-)
  } -> {[x y z.]
    ({[.z] [.x]} > |-)
  })
  (arr u64.succ.gt-base : {[x.]
    ({[.x] u64} :)
  } -> {[x.]
    ({([.x] succ) [.x]} > |-)
  })
  (arr u64.succ-eq.reflect-gt : {[x pred base.]
    ({([.pred] succ) [.x]} = |-)
    ({[.x] ([.base] succ)} > |-)
  } -> {[x pred base.]
    ({[.pred] [.base]} > |-)
  })
  # Extract the numeric value of a valid index together with its range proof.
  (arr ix.index : {[n position.]
    ([.n] ix val)
  } -> {[n position.]
    ({[.position] u64} :)
    ([.n position] > |-) 
  })
  (arr ix.extent : {[n.]
    ([.n] ix val)
  } -> {[n.]
    [.n]
  })

  (arr u64.pred : {[x pred.]
    ({[.x] u64} :)
    ({[.x] 0} > |-)
  } -> {[x pred.]
    ({[.pred] u64} :)
    ({([.pred] succ) [.x]} = |-)
  })
  (def u64.pred.lt-n : {[n x pred.]
    ({([.pred] succ) [.x]} = |-)
    ([.n x] > |-)
  } -> {[n x pred.]
    ([.n pred] > |-) 
  }
  =
  {[pred_succ_x x_lt_n.]
    ([.pred_succ_x] u64.succ-eq.gt-base [x_gt_pred.])
    ([.x_gt_pred x_lt_n] u64.gt.trans [pred_lt_n.])
    [.pred_lt_n]
  })
  (def u64.pred.gt-zero : {[x pred.]
    ({[.x] (0 succ)} > |-)
    ({([.pred] succ) [.x]} = |-)
  } -> {[x pred.]
    ({[.pred] 0} > |-)
  }
  =
  {[x_gt_succ_zero pred_succ_x.]
    ([.pred_succ_x x_gt_succ_zero] u64.succ-eq.reflect-gt [pred_gt_zero.])
    [.pred_gt_zero]
  })
  (arr ix.from-u64 : {[n position.]
    ({[.position] u64} :)
    ([.n position] > |-) 
  } -> {[n position.]
    ([.n] ix val)
  })
  (arr product.intro : {[a b.]
    ([.a])
    ([.b])
  } -> {[a b.]
    ({[.a] [.b]} *)
  })
  (arr product.elim : {[a b.]
    ({[.a] [.b]} *)
  } -> {[a b.]
    ([.a])
    ([.b])
  })
  (def pool.payload.intro :
    {[n position.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
      ({[.position] u64} :)
      ([.n position] > |-) 
    }
    ->
    {[n position.]
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.position] u64} :)
            ([.n position] > |-) 
          } *)
        } *)
      } *)
    }
    =
    {[input index u64_position position_lt_n.]
      ([.u64_position position_lt_n] product.intro [position_range.])
      ([.index position_range] product.intro [index_position_range.])
      ([.input index_position_range] product.intro [payload.])
      [.payload]
    })
  (def pool.payload.elim :
    {[n position.]
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.position] u64} :)
            ([.n position] > |-) 
          } *)
        } *)
      } *)
    }
    ->
    {[n position.]
      ({cap.ref [.n] f32} buf val)
      ([.n] ix val)
      ({[.position] u64} :)
      ([.n position] > |-) 
    }
    =
    {[payload.]
      ([.payload] product.elim [input index_position_range.])
      ([.index_position_range] product.elim [index position_range.])
      ([.position_range] product.elim [u64_position position_lt_n.])
      [.input index u64_position position_lt_n]
    })
  (arr f32.buf.store :
    {[n.]
      ({cap.own [.n] f32} buf val)
      ([.n] ix val)
      (f32 val)
    }
    ->
    {[n.]
      ({cap.own [.n] f32} buf val)
    })

  (def f32.pool-at-zero :
    {[n position.]
      ({[.position] 0} = |-)
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.position] u64} :)
            ([.n position] > |-) 
          } *)
        } *)
      } *)
    }
    -> {[n position.] (f32 val)}
    =
    {[env payload.]
      ([.payload] pool.payload.elim [input index u64_position position_lt_n.])
      ([.index input] ix [current.])
      [.current]
    })

  (def f32.pool-at-one :
    {[n position.]
      ({(0 succ) [.position]} = |-)
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.position] u64} :)
            ([.n position] > |-) 
          } *)
        } *)
      } *)
    }
    -> {[n position.] (f32 val)}
    =
    {[succ_zero_eq_position payload.]
      ([.payload] pool.payload.elim [input index u64_position position_lt_n.])
      ([.succ_zero_eq_position] u64.succ-eq.gt-base [position_gt_zero.])
      ([.u64_position position_lt_n] ix.from-u64 [current_index.])
      ([.position_gt_zero position_lt_n] u64.gt.trans [n_gt_zero.])
      ([] u64.zero [u64_zero.])
      ([.u64_zero n_gt_zero] ix.from-u64 [zero_index.])
      ([.current_index input] ix [current.])
      ([.zero_index input] ix [previous.])
      ([.current previous] f32.add [pooled.])
      [.pooled]
    })

  (def f32.pool-at-many :
    {[n position.]
      ({[.position] (0 succ)} > |-)
      ({
        ({cap.ref [.n] f32} buf val)
        ({
          ([.n] ix val)
          ({
            ({[.position] u64} :)
            ([.n position] > |-) 
          } *)
        } *)
      } *)
    }
    -> {[n position.] (f32 val)}
    =
    {[succ_zero_lt_position payload.]
      ([.payload] pool.payload.elim [input index u64_position position_lt_n.])
      ([.u64_position position_lt_n] ix.from-u64 [current_index.])
      ([] u64.zero [u64_zero.])
      ([.u64_zero] u64.succ.gt-base [succ_zero_gt_zero.])
      ([.succ_zero_gt_zero succ_zero_lt_position] u64.gt.trans [position_gt_zero.])
      ([.u64_position position_gt_zero] u64.pred [minus_one minus_one_succ_position.])
      ([.minus_one_succ_position position_lt_n] u64.pred.lt-n [minus_one_lt_n.])
      ([.succ_zero_lt_position minus_one_succ_position] u64.pred.gt-zero [minus_one_gt_zero.])
      ([.minus_one minus_one_gt_zero] u64.pred [minus_two minus_two_succ_minus_one.])
      ([.minus_two_succ_minus_one minus_one_lt_n] u64.pred.lt-n [minus_two_lt_n.])
      ([.minus_one minus_one_lt_n] ix.from-u64 [minus_one_index.])
      ([.minus_two minus_two_lt_n] ix.from-u64 [minus_two_index.])
      ([.current_index input] ix [current.])
      ([.minus_one_index input] ix [previous.])
      ([.minus_two_index input] ix [previous2.])
      ([.current previous] f32.add [partial.])
      ([.partial previous2] f32.add [pooled.])
      [.pooled]
    })

})

(def program f32.pool-nonzero :
  {[n position.]
    ({[.position] 0} > |-)
    ({
      ({cap.ref [.n] f32} buf val)
      ({
        ([.n] ix val)
        ({
          ({[.position] u64} :)
          ([.n position] > |-) 
        } *)
      } *)
    } *)
  }
  ->
  {[n position.] (f32 val)}
  =
  {[position_gt_zero payload.]
    ([.payload] pool.payload.elim [input index u64_position position_lt_n.])
    ([.index] ix.extent [extent.])
    ([.u64_position] :.unpack [position_param position_type _u64_position.])
    ([] u64.zero [u64_zero.])
    ([.u64_zero u64_position position_gt_zero] u64.is-succ [is_one one-case many-case.])
    ([.input index u64_position position_lt_n] pool.payload.intro [payload_inner.])

    # Inner if:
    #   if index == 1:
    #     input[index] + input[indesucc_zero_lt_positionx - 1]
    #   else:
    #     input[index] + input[index - 1] + input[index - 2]
    ({
      ([.one-case])
      ([.extent position_param] name.f32.pool-at-one)
      ([.many-case])
      ([.extent position_param] name.f32.pool-at-many)
      ([.is_one])
      ([.payload_inner])
    } bool.ifc [pooled.])
    [.pooled]
  }
)

(def program f32.pooling-last-three :
  {[n.]
    ({cap.ref [.n] f32} buf val)
    ({cap.own [.n] f32} buf val)
    ([.n] ix val)
  }
  ->
  {[n.]
    ({cap.own [.n] f32} buf val)
  }
  =
  {[input output index.]
    ([.index] ix.extent [extent.])
    ([.index] ix.index [u64_position position_lt_n.])
    ([.u64_position] u64.is-zero [is_zero zero_case nonzero_case.])
    ([.u64_position] :.unpack [position_param position_type _u64_position.])
    ([.input index u64_position position_lt_n] pool.payload.intro [payload.])

    # Outer if:
    #   if index == 0:
    #     input[index]
    #   else:
    #     run the nested non-zero decision above
    ({
      ([.zero_case])
      ([.extent position_param] name.f32.pool-at-zero)
      ([.nonzero_case])
      ([.extent position_param] name.f32.pool-nonzero)
      ([.is_zero])
      ([.payload])
    } bool.ifc [pooled.])

    ([.output index pooled] f32.buf.store [output_pooled.])

    [.output_pooled]
  }
)
