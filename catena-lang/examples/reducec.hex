# Dot product of two u64 buffers using reducec.
#
# This example follows the materializec examples from marco/materializec:
# input memory is cast to typed buffers, the scalar result is materialized as a
# same-length owned u64 buffer, and then returned as owned memory.

# product-at : buf n u64 * buf n u64 * ix n -> u64
(def program dot-u64-product-at :
  ([n.] {
    ({cap.ref [.n] u64} buf val)
    ({cap.ref [.n] u64} buf val)
    ([.n] ix val)
  })
  ->
  ([n.] (u64 val))
= ([lhs rhs i.]
  {
    {[.i lhs]} ix
    {[.i rhs]} ix
  }
  u64.mul
))

# Constant producer used to materialize the scalar dot product back into owned
# memory. The output uses the same length index as the left input because this
# stdlib does not yet expose a type-level u64 literal for a one-element buffer.
(def program dot-u64-result-at :
  ([n.] {(u64 val) ([.n] ix val)})
  ->
  ([n.] (u64 val))
= ([value i.] [.value]))

(def program dot-u64 :
  {(cap.ref mem) (cap.ref mem)}
  ->
  (cap.own mem)
= (
  {mem.cast.u64 mem.cast.u64}
  [lhs-len lhs rhs-len rhs.]
    {
      # output length for the materialized scalar result
      [.lhs-len]

      {
        # zero
        u64.zero

        # accumulator closure: no runtime environment, direct function pointer
        name.u64.add

        # producer closure: both input buffers as environment plus function pointer
        [.lhs rhs]
        (([.lhs-len] :.param) name.dot-u64-product-at)

        # reduction length
        [.lhs-len]
      }
      reducec

      # materialize the scalar as an owned buffer
      ({[dot.] [.dot] (([.lhs-len] :.param) name.dot-u64-result-at) [.lhs-len]}
        materializec)
    }
    buf.to-mem
))
