# Catena-lang analogue of examples/puzzles/pooling.hex.
#
# This file declares the extra arithmetic/index primitives it needs locally,
# instead of extending catena-lang/stdlib/*.hex.
#
# It models the per-index pooling behavior:
#
#   output[0] = input[0]
#   output[1] = input[1] + input[0]
#   output[i] = input[i] + input[i - 1] + input[i - 2], for i >= 2
#
# Unlike the core example, this does not use gpu.global or gpu views. It uses a
# simple input/output buffers plus an index. The nested branch program computes
# the pooled value at that index; the store wrapper writes it to the output.
#
# NOTE: this is a language-level example. The current catena-lang HIP renderer
# does not yet lower these locally declared f32/index primitives.

(theory type nat {
  (arr f32 : 0 -> 1)
})

(theory program type {
  # Local arithmetic and index primitives for this example.
  # Compare an index with a u64 value.
  (arr ix.eq : {[rhs.] (u64 ix val) ([.rhs])} -> {[rhs.] (bool val)})
  (arr ix.sub : {(u64 ix val) (u64 val)} -> (u64 ix val))
  (arr u64.one : [] -> (u64 val))
  (arr u64.add : {(u64 val) (u64 val)} -> (u64 val))
  (arr f32.add : {(f32 val) (f32 val)} -> (f32 val))
  (arr product.intro :
    {
      ({cap.ref u64 f32} buf val)
      (u64 ix val)
    }
    ->
    ({
      ({cap.ref u64 f32} buf val)
      (u64 ix val)
    } *))
  (arr product.elim :
    ({
      ({cap.ref u64 f32} buf val)
      (u64 ix val)
    } *)
    ->
    {
      ({cap.ref u64 f32} buf val)
      (u64 ix val)
    })
  (def pool.payload.intro :
    {
      ({cap.ref u64 f32} buf val)
      (u64 ix val)
    }
    ->
    ({
      ({cap.ref u64 f32} buf val)
      (u64 ix val)
    } *)
    =
    ([input index.]
      [.input index] product.intro [payload.]
      [.payload]
    ))
  (def pool.payload.elim :
    ({
      ({cap.ref u64 f32} buf val)
      (u64 ix val)
    } *)
    ->
    {
      ({cap.ref u64 f32} buf val)
      (u64 ix val)
    }
    =
    ([payload.]
      [.payload] product.elim [input index.]
      [.input index]
    ))
  (arr f32.buf.store :
    {
      ({cap.own u64 f32} buf val)
      (u64 ix val)
      (f32 val)
    }
    ->
    ({cap.own u64 f32} buf val))

  (def u64.two :
    []
    ->
    (u64 val)
    =
    (([.] u64.one [one_l.])
     ([.] u64.one [one_r.])
     [.one_l one_r] u64.add [two.]
     [.two]))

  (def f32.pool-at-zero :
    {
      1
      ({
        ({cap.ref u64 f32} buf val)
        (u64 ix val)
      } *)
    }
    ->
    (f32 val)
    =
    ([env payload.]
      [.payload] pool.payload.elim [input index.]
      [.index input] ix [current.]
      [.current]
    ))

  (def f32.pool-at-one :
    {
      1
      ({
        ({cap.ref u64 f32} buf val)
        (u64 ix val)
      } *)
    }
    ->
    (f32 val)
    =
    ([env payload.]
      [.payload] pool.payload.elim [input index.]
      ([.] u64.one [one.])
      [.index one] ix.sub [index_prev.]
      [.index input] ix [current.]
      [.index_prev input] ix [previous.]
      [.current previous] f32.add [sum.]
      [.sum]
    ))

  (def f32.pool-at-many :
    {
      1
      ({
        ({cap.ref u64 f32} buf val)
        (u64 ix val)
      } *)
    }
    ->
    (f32 val)
    =
    ([env payload.]
      [.payload] pool.payload.elim [input index.]
      ([.] u64.one [one.])
      ([.] u64.two [two.])
      [.index one] ix.sub [index_prev.]
      [.index two] ix.sub [index_prev2.]
      [.index input] ix [current.]
      [.index_prev input] ix [previous.]
      [.index_prev2 input] ix [previous2.]
      [.current previous] f32.add [partial.]
      [.partial previous2] f32.add [sum.]
      [.sum]
    ))

})

(def program f32.pool-nonzero :
  {
    (bool val)
    ({
      ({cap.ref u64 f32} buf val)
      (u64 ix val)
    } *)
  }
  ->
  (f32 val)
  =
  ([is_one payload.]
    {
      unit.intro
      name.f32.pool-at-one
      unit.intro
      name.f32.pool-at-many
      [. is_one payload]
    }
    bool.ifc
  )
)

(def program f32.pooling-last-three-at :
  {
    (bool val)
    (bool val)
    ({
      ({cap.ref u64 f32} buf val)
      (u64 ix val)
    } *)
  }
  ->
  (f32 val)
  =
  ([is_zero is_one payload.]
    # Outer if:
    #   if index == 0:
    #     input[index]
    #   else:
    #     run the nested non-zero decision above
    {
      unit.intro
      name.f32.pool-at-zero
      [.is_one]
      name.f32.pool-nonzero
      [. is_zero payload]
    }
    bool.ifc
  )
)

(def program f32.pooling-last-three-store :
  {
    ({cap.ref u64 f32} buf val)
    ({cap.own u64 f32} buf val)
    (u64 ix val)
  }
  ->
  ({cap.own u64 f32} buf val)
  =
  ([input output index.]
    ([.] u64.zero [zero.])
    ([.] u64.one [one.])
    [.index zero] ix.eq [is_zero.]
    [.index one] ix.eq [is_one.]

    [.input index] pool.payload.intro [payload.]

    [.is_zero is_one payload] f32.pooling-last-three-at [pooled.]

    [.output index pooled] f32.buf.store [output_pooled.]

    [.output_pooled]
  )
)
