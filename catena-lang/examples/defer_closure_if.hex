(def program f32.id : (f32 val) -> (f32 val) = [x])

# Build a closure, feed it through defer/run as data, then consume it with
# bool.if. The public boundary has no closure type.
(def program defer-closure-if : {(bool val) (f32 val)} -> (f32 val) = ([b x.]
  {
    (name.f32.id lift defer run)
    (name.f32.neg lift)
    [.b]
    [.x]
  }
  bool.if
))
