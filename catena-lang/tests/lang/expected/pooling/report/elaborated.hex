  (arr u64.gt : {[x y b . ] ({[ . x] u64} :) ({[ . y] u64} :)} -> {[x y b . ] ({[ . b] bool.t} = [b_true . ]) ({[ . b] bool.f} = [b_false . ]) ([ . x y] > [x_gt_y . ]) ({[ . b] bool} :) ([ . b_true x_gt_y] ==> |-) ([ . x_gt_y] {[ . b_false] not} ==> |-)})
