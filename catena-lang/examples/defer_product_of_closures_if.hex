(def program f32.id : (f32 val) -> (f32 val) = [x])

# Build a product of closures, pass that product through defer/run as data,
# then unpack it and consume the closures with bool.if. The public boundary has
# no closure type, but the deferred product contains closures.
#
# This currently fails during closure conversion. The two closures passed to
# bool.if both come out of the same *.elim. Converting either output discovers a
# region that includes the shared *.elim edge, so rewriting one closure deletes
# the sibling closure wire that bool.if still needs.
#
#   name.f32.id  lift -.
#                    *.intro -> defer -> run -> *.elim - n9  -.
#   name.f32.neg lift -'                         `---- n10 -' bool.if
#
# When converting n9, the selected region includes *.elim. But *.elim also
# produces n10, so n10 is deleted even though bool.if still references it.
(def program defer-product-of-closures-if : {(bool val) (f32 val)} -> (f32 val) = ([b x.]
  {
    (
      {(name.f32.id lift) (name.f32.neg lift)}
      *.intro
      defer
      run
      *.elim
    )
    [.b]
    [.x]
  }
  bool.if
))
