# Examples using reducec.

# Adapter from the environmentful reducec accumulator convention to direct u64.add.
(def program u64.add-env :
  {1 (u64 val) (u64 val)}
  ->
  (u64 val)
= ([env acc value.]
  {[.acc value]} u64.add
))

# Read one u64 element from a converted buffer at an index.
(def program sum-u64-at :
  ([n.] {
    ({cap.ref [.n] u64} buf val)
    ([.n] ix val)
  })
  ->
  ([n.] (u64 val))
= ([input i.]
  {[.i input]} ix
))

# Sum all u64 elements in a memory buffer.
(def program sum-u64 :
  (cap.ref mem)
  ->
  (u64 val)
= (
  mem.cast.u64
  [len input.]
    {
      # zero
      const.u64.0x0000000000000000

      # accumulator closure: unit environment plus adapter function pointer
      unit.intro
      name.u64.add-env

      # producer closure: buffer as environment plus function pointer
      ({[.input] (([.len] :.param) name.sum-u64-at)})

      # reduction length
      [.len]
    }
    reducec
))

