  (arr f32.buf.store : {({cap.own u64 f32} buf val) (u64 ix val) (f32 val)} -> ({cap.own u64 f32} buf val))
  (def f32.pool-at-many : {1 ({({cap.own u64 f32} buf val) (u64 ix val)} *)} -> (f32 val) = ([env payload . ] [ . env] unit.drop [] [ . payload] f32.pool.payload.elim [input index . ] [ . index] ix.copy [index_current index_rest . ] [ . index_rest] ix.copy [index_prev_base index_prev2_base . ] ([] u64.one [one . ]) ([] u64.two [two . ]) [ . index_prev_base one] ix.sub [index_prev . ] [ . index_prev2_base two] ix.sub [index_prev2 . ] [ . input index_current] f32.buf.load [input_after_current current . ] [ . input_after_current index_prev] f32.buf.load [input_after_previous previous . ] [ . input_after_previous index_prev2] f32.buf.load [input_after_previous2 previous2 . ] [ . input_after_previous2] f32.buf.drop [] [ . current previous] f32.add [partial . ] [ . partial previous2] f32.add [sum . ] [ . sum]))
  (def f32.pool-at-one : {1 ({({cap.own u64 f32} buf val) (u64 ix val)} *)} -> (f32 val) = ([env payload . ] [ . env] unit.drop [] [ . payload] f32.pool.payload.elim [input index . ] [ . index] ix.copy [index_current index_prev_base . ] ([] u64.one [one . ]) [ . index_prev_base one] ix.sub [index_prev . ] [ . input index_current] f32.buf.load [input_after_current current . ] [ . input_after_current index_prev] f32.buf.load [input_after_previous previous . ] [ . input_after_previous] f32.buf.drop [] [ . current previous] f32.add [sum . ] [ . sum]))
  (def f32.pool-at-zero : {1 ({({cap.own u64 f32} buf val) (u64 ix val)} *)} -> (f32 val) = ([env payload . ] [ . env] unit.drop [] [ . payload] f32.pool.payload.elim [input index . ] [ . input index] f32.buf.load [input_after_current current . ] [ . input_after_current] f32.buf.drop [] [ . current]))
  (def f32.pool-nonzero : {(bool val) ({({cap.own u64 f32} buf val) (u64 ix val)} *)} -> (f32 val) = ([is_one payload . ] {unit.intro name.f32.pool-at-one unit.intro name.f32.pool-at-many [ . is_one payload]} bool.ifc))
  (arr f32.pool.payload.elim : ({({cap.own u64 f32} buf val) (u64 ix val)} *) -> {({cap.own u64 f32} buf val) (u64 ix val)})
  (arr f32.pool.payload.intro : {({cap.own u64 f32} buf val) (u64 ix val)} -> ({({cap.own u64 f32} buf val) (u64 ix val)} *))
  (def f32.pooling-last-three-at : {(bool val) (bool val) ({({cap.own u64 f32} buf val) (u64 ix val)} *)} -> (f32 val) = ([is_zero is_one payload . ] {unit.intro name.f32.pool-at-zero [ . is_one] name.f32.pool-nonzero [ . is_zero payload]} bool.ifc))
  (def f32.pooling-last-three-store : {({cap.own u64 f32} buf val) ({cap.own u64 f32} buf val) (u64 ix val)} -> ({cap.own u64 f32} buf val) = ([input output index . ] [ . index] ix.copy [index_payload_source index_store . ] [ . index_payload_source] ix.copy [index_payload index_pred . ] [ . index_pred] ix.copy [index_zero index_one . ] [ . index_zero] ix.is-zero [is_zero . ] [ . index_one] ix.is-one [is_one . ] [ . input index_payload] f32.pool.payload.intro [payload . ] [ . is_zero is_one payload] f32.pooling-last-three-at [pooled . ] [ . output index_store pooled] f32.buf.store [output_pooled . ] [ . output_pooled]))
