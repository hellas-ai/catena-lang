# sigmoid(x) = 1 / (1 + exp(-x))
(def program sigmoid : (f32 val) -> (f32 val) =
  {[x.]
    (f32.one [one.])

    ([.x] f32.neg [neg_x.])
    ([.neg_x] exp-approx [exp_neg_x.])
    ([.one exp_neg_x] f32.add [denominator.])
    ([.one denominator] f32.div [result.])
    [.result]
  }
)

# silu(x) = x * sigmoid(x)
(def program silu : (f32 val) -> (f32 val) =
  {[x.]
    ([.x] sigmoid [gate.])
    ([.x gate] f32.mul [result.])
    [.result]
  }
)

# tanh(x) = 2 * sigmoid(2x) - 1
(def program tanh : (f32 val) -> (f32 val) =
  {[x.]
    (f32.one [one.])
    (const.u32.0x40000000 u32.bitcast-f32 [two.])

    ([.x two] f32.mul [twice_x.])
    ([.twice_x] sigmoid [sigma.])
    ([.sigma two] f32.mul [twice_sigma.])
    ([.twice_sigma one] f32.sub [result.])
    [.result]
  }
)

# approx GELU(x) ≈ 0.5 * x * (1 + tanh(sqrt(2/pi) * (x + 0.044715 * x^3)))
(def program gelu-approx : (f32 val) -> (f32 val) =
  {[x.]
    (f32.one [one.])
    (const.u32.0x3F000000 u32.bitcast-f32 [half.])
    (const.u32.0x3F4C422A u32.bitcast-f32 [sqrt_2_over_pi.])
    (const.u32.0x3D372713 u32.bitcast-f32 [cubic_coeff.])

    ([.x x] f32.mul [x2.])
    ([.x2 x] f32.mul [x3.])
    ([.x3 cubic_coeff] f32.mul [cubic_term.])
    ([.x cubic_term] f32.add [inner.])
    ([.inner sqrt_2_over_pi] f32.mul [scaled.])
    ([.scaled] tanh [shaped.])
    ([.one shaped] f32.add [gate.])
    ([.x gate] f32.mul [gated_x.])
    ([.gated_x half] f32.mul [result.])
    [.result]
  }
)

# Read exp(x_i - max_x) from a buffer environment for a stable softmax denominator.
(def program softmax-exp-shifted-at :
  ([n.] {
    ({({cap.ref [.n] f32} buf val) (f32 val)} *)
    ([.n] ix val)
  })
  ->
  ([n.] (f32 val))
= {[env i.]
  ([.env] *.elim [input max-x.])
  ({[.i input]} ix [x-i.])
  ([.x-i max-x] f32.sub [shifted.])
  ([.shifted] exp-approx [result.])
  [.result]
})

# Materialize exp(x_i - max_x) / denom for a stable softmax output buffer.
(def program softmax-at :
  ([n.] {
    ({({({cap.ref [.n] f32} buf val) (f32 val)} *) (f32 val)} *)
    ([.n] ix val)
  })
  ->
  ([n.] (f32 val))
= {[env i.]
  ([.env] *.elim [input-and-max denom.])
  ([.input-and-max] *.elim [input max-x.])
  ({[.i input]} ix [x-i.])
  ([.x-i max-x] f32.sub [shifted.])
  ([.shifted] exp-approx [numerator.])
  ([.numerator denom] f32.div [result.])
  [.result]
})

# Stable softmax over an f32 buffer. Caller must provide a non-empty input.
(def program softmax :
  (cap.ref mem)
  ->
  (cap.own mem)
= (
  mem.cast.f32
  [len input.]
    {
      ({
        (const.u32.0xFF800000 u32.bitcast-f32)
        unit.intro
        name.f32.max-env
        ({[.input] (([.len] :.param) name.f32-at)})
        [.len]
      } reducec [max-x.])
      ({
        (const.u32.0x00000000 u32.bitcast-f32)
        unit.intro
        name.f32.add-env
        ({({[.input] [.max-x]} *.intro) (([.len] :.param) name.softmax-exp-shifted-at)})
        [.len]
      } reducec [denom.])
      {
        [.len]
        ({[.len] ({({[.input] [.max-x]} *.intro) [.denom]} *.intro) (([.len] :.param) name.softmax-at)}
          materializec)
      }
    }
    buf.to-mem
))
