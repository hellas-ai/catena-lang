(def program f32.id : (f32 val) -> (f32 val) = [x])

# Fully applies a closure to an argument:
#
#   f : f32 => f32
#   x : f32
#   result = f(x)
(def program apply-closure :
  {({(f32 val) (f32 val)} =>) (f32 val)}
  ->
  (f32 val)
= ([f x.]
  {([.x] defer) [.f]}
  compose
  run
))

# Partially applies apply-closure to both:
#
#   f : f32 => f32
#   x : f32
#
# and returns a nullary closure:
#
#   1 => f32
#
# The returned closure is:
#
#   x -- defer --.
#               compose --> 1 => f32
#   f ----------'
(def program partial-apply-closure :
  {({(f32 val) (f32 val)} =>) (f32 val)}
  ->
  ({1 (f32 val)} =>)
= ([f x.]
  {([.x] defer) [.f]}
  compose
))

# Public closure-free example. The closure is obtained by partially applying a
# function that takes another closure and an argument, then the resulting
# nullary closure is run.
(def program run-partial-applied-closure : (f32 val) -> (f32 val) = ([x.]
  ({(name.f32.id lift) [.x]} partial-apply-closure)
  run
))
