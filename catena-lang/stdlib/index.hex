################################################################################
# Indices
(theory type nat {
  # indices
  # `ix n` is a valid index into any `buf m n t`.
  (arr ix : 1 -> 1)

  # Numerics (TODO!)
  (arr 0 : 0 -> 1)
  (arr > : 2 -> 1)
})

(theory program type {
  # indexing buffers
  # val(ix n) ● val(buf m n t) -> val(t)
  (arr ix : {[m n t.] ([.n] ix val) ([.m n t] buf val)} -> ([m n t . t] val))

  # the zero index
  # ix.zero : (|- n > 0) -> val(ix n)
  (arr ix.zero : ({[n] 0} > |-) -> (ix val))

  (def ix.copy :
    ([n.] ([.n] ix val))
    ->
    ([n.] {([.n] ix val) ([.n] ix val)})
    =
    ([i.] {[.i] [.i]})
  )

  # Row-major layout helpers for flattened matrix buffers.
  # row-major-index(cols, row, col) -> flat
  (arr row-major-index :
    ([n k.] {
      ({[.k] u64} :)
      ({([.n] ix val) ([.k] ix val)} *)
    })
    ->
    ([n k.] (({[.n] [.k]} *) ix val)))

  # row-major-row(cols, flat) -> row
  (arr row-major-row :
    ([n m.] {
      ({[.m] u64} :)
      (({[.n] [.m]} *) ix val)
    })
    ->
    ([n m.] ([.n] ix val)))

  # row-major-col(cols, flat) -> col
  (arr row-major-col :
    ([n m.] {
      ({[.m] u64} :)
      (({[.n] [.m]} *) ix val)
    })
    ->
    ([n m.] ([.m] ix val)))
})
