# Log approximation for positive, normalized f32 inputs.
# Decompose x by bit manipulation into
#   x = m * 2^e
# with m in [0.5, 1), then apply the reference cubic:
#   log(x) ~= poly(m) + e * ln(2)

(def program log-approx : (f32 val) -> (f32 val) =
  {[x.]
    ([.] const.u32.0x007FFFFF [frac_mask.])
    ([.] const.u32.0x00000017 [exp_shift.])
    ([.] const.u32.0x3F000000 [mantissa_half_bits.])
    ([.] const.u32.0x0000007E [mantissa_bias_u32.])
    ([.] const.u32.0x3F317218 [ln2_bits.])
    ([.] const.u32.0xC00BE629 [c0_bits.])
    ([.] const.u32.0x4087355A [c1_bits.])
    ([.] const.u32.0xC03AA687 [c2_bits.])
    ([.] const.u32.0x3F60A4E1 [c3_bits.])

    ([.x] f32.bitcast-u32 [x_bits.])
    ([.x_bits exp_shift] u32.shr [exp_bits.])
    ([.x_bits frac_mask] u32.and [frac_bits.])

    ([.frac_bits mantissa_half_bits] u32.add [m_bits.])
    ([.m_bits] u32.bitcast-f32 [m.])

    ([.exp_bits] u32.to-f32 [exp_f.])
    ([.mantissa_bias_u32] u32.to-f32 [mantissa_bias.])
    ([.exp_f mantissa_bias] f32.sub [e.])

    ([.ln2_bits] u32.bitcast-f32 [ln2.])
    ([.c0_bits] u32.bitcast-f32 [c0.])
    ([.c1_bits] u32.bitcast-f32 [c1.])
    ([.c2_bits] u32.bitcast-f32 [c2.])
    ([.c3_bits] u32.bitcast-f32 [c3.])

    ([.m c3] f32.mul [m_c3.])
    ([.c2 m_c3] f32.add [p2.])
    ([.m p2] f32.mul [m_p2.])
    ([.c1 m_p2] f32.add [p1.])
    ([.m p1] f32.mul [m_p1.])
    ([.c0 m_p1] f32.add [rl.])

    ([.e ln2] f32.mul [elog2.])
    ([.rl elog2] f32.add [result.])
    [.result]
  }
)
