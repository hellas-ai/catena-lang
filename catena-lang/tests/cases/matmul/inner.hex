# Minimal matmul-f32-inner codegen smoke test.
#
# The lhs and rhs closures ignore the index and return 1.0. The wrapper calls
# the stdlib matmul-f32-inner directly; it should compute the inner product of
# those two simple producers once the current closure-region issue is fixed.

(def program matmul-test.f32-one-at-lhs :
  ([b.] ([.b] ix val))
  ->
  ([b.] (f32 val))
= ([i.] f32.one))

(def program matmul-test.f32-one-at-rhs :
  ([b.] ([.b] ix val))
  ->
  ([b.] (f32 val))
= ([i.] f32.one))

(def program matmul-test.f32-inner-ones :
  ([b.] {
    ({[.b] u64} :)
    (([.b] ix val) ty)
  })
  ->
  ([b.] (f32 val))
= ([b-len ix-b-ty.]
  ([.b-len] :.ty [b-len-for-reduce b-dim b-u64-ty.]
    {
      [.b-len-for-reduce]
      [.ix-b-ty]
      ([.b-dim] name.matmul-test.f32-one-at-lhs lift)
      ([.b-dim] name.matmul-test.f32-one-at-rhs lift)
    }
    matmul-f32-inner
  )
))
