# sigmoid(x) = 1 / (1 + exp(-x))
(def program sigmoid : (f32 val) -> (f32 val) =
  {[x.]
    (f32.one [one.])

    ([.x] f32.neg [neg_x.])
    ([.neg_x] exp-approx [exp_neg_x.])
    ([.one exp_neg_x] f32.add [denominator.])
    ([.one denominator] f32.div [result.])
    [.result]
  }
)

# silu(x) = x * sigmoid(x)
(def program silu : (f32 val) -> (f32 val) =
  {[x.]
    ([.x] sigmoid [gate.])
    ([.x gate] f32.mul [result.])
    [.result]
  }
)

# tanh(x) = 2 * sigmoid(2x) - 1
(def program tanh : (f32 val) -> (f32 val) =
  {[x.]
    (f32.one [one.])
    (const.u32.0x40000000 u32.bitcast-f32 [two.])

    ([.x two] f32.mul [twice_x.])
    ([.twice_x] sigmoid [sigma.])
    ([.sigma two] f32.mul [twice_sigma.])
    ([.twice_sigma one] f32.sub [result.])
    [.result]
  }
)

# approx GELU(x) ≈ 0.5 * x * (1 + tanh(sqrt(2/pi) * (x + 0.044715 * x^3)))
(def program gelu-approx : (f32 val) -> (f32 val) =
  {[x.]
    (f32.one [one.])
    (const.u32.0x3F000000 u32.bitcast-f32 [half.])
    (const.u32.0x3F4C422A u32.bitcast-f32 [sqrt_2_over_pi.])
    (const.u32.0x3D372713 u32.bitcast-f32 [cubic_coeff.])

    ([.x x] f32.mul [x2.])
    ([.x2 x] f32.mul [x3.])
    ([.x3 cubic_coeff] f32.mul [cubic_term.])
    ([.x cubic_term] f32.add [inner.])
    ([.inner sqrt_2_over_pi] f32.mul [scaled.])
    ([.scaled] tanh [shaped.])
    ([.one shaped] f32.add [gate.])
    ([.x gate] f32.mul [gated_x.])
    ([.gated_x half] f32.mul [result.])
    [.result]
  }
)
