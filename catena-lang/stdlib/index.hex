################################################################################
# Indices
(theory type nat {
  # indices
  # `ix n` is a valid index into any `buf m n t`.
  (arr ix : 1 -> 1)

  # Numerics (TODO!)
  (arr 0 : 0 -> 1)
  (arr > : 2 -> 1)
})

(theory program type {
  # indexing buffers
  # val(ix n) ● val(buf m n t) -> val(t)
  (arr ix : {[m n t.] ([.n] ix val) ([.m n t] buf val)} -> ([m n t . t] val))

  # Reverse `ix`'s arguments so partial application can capture any buffer:
  #
  #   ix.flipped(buffer, index) = ix(index, buffer)
  (def ix.flipped :
    ([m n t.] {
      ([.m n t] buf val)
      ([.n] ix val)
    })
    ->
    ([m n t . t] val)
  = ([input i.]
    {[.i input]} ix
  ))

  # Forget the index wrapper and expose the underlying runtime u64.
  (arr ix.to-u64 : ([n.] ([.n] ix val)) -> ([n.] (u64 val)))

  # Refine an already-proven in-bounds u64 into an index for a buffer of
  # length n.
  (arr u64.to-ix : {[x n.]
    ({[.x] u64} :)
    ({[.n] u64} :)
    ([.n x] > |-)
  } -> ([x n.] ([.n] ix val)))

  # the zero index
  # ix.zero : (|- n > 0) -> val(ix n)
  (arr ix.zero : ({[n] 0} > |-) -> (ix val))

  (def ix.copy :
    ([n.] ([.n] ix val))
    ->
    ([n.] {([.n] ix val) ([.n] ix val)})
    =
    ([i.] {[.i] [.i]})
  )

  # Row-major layout helpers for flattened matrix buffers.
  # These operations are common enough that we define them as primitives instead
  # of proving their arithmetic with inline certificates at each use site.
  # row-major-index(cols, row, col) -> flat
  (arr row-major-index :
    ([n k.] {
      ({[.k] u64} :)
      ({([.n] ix val) ([.k] ix val)} *)
    })
    ->
    ([n k.] (({[.n] [.k]} *) ix val)))

  # row-major-row(cols, flat) -> row
  (arr row-major-row :
    ([n m.] {
      ({[.m] u64} :)
      (({[.n] [.m]} *) ix val)
    })
    ->
    ([n m.] ([.n] ix val)))

  # row-major-col(cols, flat) -> col
  (arr row-major-col :
    ([n m.] {
      ({[.m] u64} :)
      (({[.n] [.m]} *) ix val)
    })
    ->
    ([n m.] ([.m] ix val)))
})
