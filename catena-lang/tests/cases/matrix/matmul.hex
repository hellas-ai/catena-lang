# mems -> typed buffers -> row-major matrix views -> matmul -> materialized mem
(def program matmul-2x2-via-mem :
  ([n m k.] {
    (cap.ref mem)
    (cap.ref mem)
    ({[.n] u64} :)
    ({[.m] u64} :)
    ({[.k] u64} :)
    ({({[.n] [.k]} *) u64} :)
    ({({[.k] [.m]} *) u64} :)
    ({({[.n] [.m]} *) u64} :)
  })
  ->
  ([n m k.] (cap.own mem))
= ([a-mem b-mem n-len m-len k-len nk-len km-len nm-len.]
  ([.a-mem] mem.cast.f32 [actual-nk-len a-raw.]
    ([.b-mem] mem.cast.f32 [actual-km-len b-raw.]
      ([.nk-len actual-nk-len] u64.eq [a-len-eq if-a-len-eq _if-a-len-ne.]
        ([.km-len actual-km-len] u64.eq [b-len-eq if-b-len-eq _if-b-len-ne.]
          ({
            [.a-len-eq]
            [.if-a-len-eq]
          } assert-then [a-same-length.]
            ({
              [.b-len-eq]
              [.if-b-len-eq]
            } assert-then [b-same-length.]
              ({[.a-raw] [.a-same-length]} buf.f32.cast-same-length [a.]
                ({[.b-raw] [.b-same-length]} buf.f32.cast-same-length [b.]
                  ([.n-len] u64.copies2 [a-rows materialize-n.]
                    ([.m-len] u64.copies2 [b-cols materialize-m.]
                      ([.k-len] u64.copies3 [a-cols b-rows materialize-k.]
                        ({cap.ref.type ([.nk-len] :.param) f32.type [.a]} partial.ix.flipped.1 [a-flat-view.]
                          ({[.a-rows] [.a-cols] [.a-flat-view]} f32.row-major.matrix-view [a-view.]
                            ({cap.ref.type ([.km-len] :.param) f32.type [.b]} partial.ix.flipped.1 [b-flat-view.]
                              ({[.b-rows] [.b-cols] [.b-flat-view]} f32.row-major.matrix-view [b-view.]
                                ([.nm-len] u64.copies2 [output-len mem-len.]
                                  ({
                                    [.materialize-n]
                                    [.materialize-m]
                                    [.materialize-k]
                                    [.output-len]
                                    [.a-view]
                                    [.b-view]
                                  } f32.matmul.row-major.materialize [result.]
                                    {[.mem-len] [.result]} buf.to-mem)
                                )
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    )
  )
))

# mem -> typed buffer -> matrix view, multiplied by the shared identity view
(def program matmul-right-identity-2x2-via-mem :
  ([n.] {
    (cap.ref mem)
    ({[.n] u64} :)
    ({({[.n] [.n]} *) u64} :)
  })
  ->
  ([n.] (cap.own mem))
= ([a-mem n-len nn-len.]
  ([.a-mem] mem.cast.f32 [actual-nn-len a-raw.]
    ([.nn-len actual-nn-len] u64.eq [a-len-eq if-a-len-eq _if-a-len-ne.]
      ({
        [.a-len-eq]
        [.if-a-len-eq]
      } assert-then [a-same-length.]
        ({[.a-raw] [.a-same-length]} buf.f32.cast-same-length [a.]
          ([.n-len] u64.copies6 [view-rows view-cols identity-n materialize-n materialize-m materialize-k.]
            ([.nn-len] u64.copies3 [flat-view-len output-len mem-len.]
              ({cap.ref.type ([.flat-view-len] :.param) f32.type [.a]} partial.ix.flipped.1 [flat-view.]
                ({[.view-rows] [.view-cols] [.flat-view]} f32.row-major.matrix-view [a-view.]
                  (([.identity-n] :.param) name.f32.matrix.identity-at lift [identity-view.]
                    ({
                      [.materialize-n]
                      [.materialize-m]
                      [.materialize-k]
                      [.output-len]
                      [.a-view]
                      [.identity-view]
                    } f32.matmul.row-major.materialize [result.]
                      {[.mem-len] [.result]} buf.to-mem)
                  )
                )
              )
            )
          )
        )
      )
    )
  )
))

# shared identity view multiplied by the matrix view derived from the input mem
(def program matmul-left-identity-2x2-via-mem :
  ([n.] {
    (cap.ref mem)
    ({[.n] u64} :)
    ({({[.n] [.n]} *) u64} :)
  })
  ->
  ([n.] (cap.own mem))
= ([a-mem n-len nn-len.]
  ([.a-mem] mem.cast.f32 [actual-nn-len a-raw.]
    ([.nn-len actual-nn-len] u64.eq [a-len-eq if-a-len-eq _if-a-len-ne.]
      ({
        [.a-len-eq]
        [.if-a-len-eq]
      } assert-then [a-same-length.]
        ({[.a-raw] [.a-same-length]} buf.f32.cast-same-length [a.]
          ([.n-len] u64.copies6 [view-rows view-cols identity-n materialize-n materialize-m materialize-k.]
            ([.nn-len] u64.copies3 [flat-view-len output-len mem-len.]
              ({cap.ref.type ([.flat-view-len] :.param) f32.type [.a]} partial.ix.flipped.1 [flat-view.]
                ({[.view-rows] [.view-cols] [.flat-view]} f32.row-major.matrix-view [a-view.]
                  (([.identity-n] :.param) name.f32.matrix.identity-at lift [identity-view.]
                    ({
                      [.materialize-n]
                      [.materialize-m]
                      [.materialize-k]
                      [.output-len]
                      [.identity-view]
                      [.a-view]
                    } f32.matmul.row-major.materialize [result.]
                      {[.mem-len] [.result]} buf.to-mem)
                  )
                )
              )
            )
          )
        )
      )
    )
  )
))
