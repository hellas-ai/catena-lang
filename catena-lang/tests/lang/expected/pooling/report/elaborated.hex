(theory program type {
  (arr :.forget : : -> ([x t . t] val))
  (arr assert : ({[b . b] bool} :) -> ({[b . b] bool.t} = |-))
  (def assert-then : {[b p . ] ({[ . b] bool} :) ({({[ . b] bool.t} =) [ . p]} ==> |-)} -> ([b p . p] |-) = ({assert [h . h]} ax-mp))
  (arr ax-mp : {[ph ps . ] ([ . ph] |-) ([ . ph ps] ==> |-)} -> ([ph ps . ps] |-))
  (arr bool.and : {(bool val) (bool val)} -> (bool val))
