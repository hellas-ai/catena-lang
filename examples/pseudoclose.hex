# Pseudo-close a feedback loop with an explicit backward wire.
#
# The tempting signatures
#
#   cap : [] -> [. a a]
#   cup : [a a .] -> []
#
# are not real cartesian syntax types: [. a a] and [a a .] are not built from
# copy/discard.  Instead, mark one leg as the loopback wire.
#
#   cap : state -> {(state loopback) state}
#   cup : {state (state loopback)} -> state
#
# The two wires are alternatives in the fake loop, not parallel signals.

(theory syntax nat {
  (arr state : 0 -> 1)
  (arr loopback : 1 -> 1)
})

(theory control syntax {
  (arr cap : state -> {(state loopback) state})
  (arr cup : {state (state loopback)} -> state)

  (arr step : state -> {state state})

  # The two legs of the bend are alternatives: continue, or close.
  (def pseudo-close :
    state ->
    state
    =
    (cap
    {[back current.]
      # `next` continues through cup; `out` exits directly.
      ([.current] step [next out.])
      ([.next back] cup [out.])
      ([.out])
    }))
})
